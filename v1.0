}

// MARK: - Editor

struct EventEditorView: View {
    @EnvironmentObject var store: GolfStore
    @Environment(\.dismiss) var dismiss

    let date: Date

    @State private var course = ""
    @State private var partners = ""
    @State private var memo = ""
    @State private var status: DayStatus = .golf
    @State private var editingEvent: GolfEvent?
    @State private var selectedPhoto: PhotosPickerItem?
    @State private var scoreImageFileName: String?
    @State private var calendarEventID: String?
    @State private var showScore = false

    var body: some View {
        NavigationStack {
            Form {
                Section("날짜") {
                    Text(dateText(date))
                }

                Section("일정 종류") {
                    Picker("종류", selection: $status) {
                        Text("골프 라운딩").tag(DayStatus.golf)
                        Text("라운딩 불가").tag(DayStatus.unavailable)
                    }
                    .pickerStyle(.segmented)
                }

                if status == .golf {
                    Section("라운딩 정보") {
                        TextField("골프장 이름", text: $course)

                        if store.revealPrivateInfo {

                            TextField(

                                "동반자: 홍길동, 김철수",

                                text: $partners

                            )

                        } else {

                            Button {

                                authenticateToReveal { success in

                                    if success {

                                        store.revealPrivateInfo = true

                                    }

                                }

                            } label: {

                                HStack {

                                    Text("동반자")

                                        .foregroundColor(.primary)

                                    Spacer()

                                    Text(maskedPartnerNames(partners, revealed: false))

                                        .foregroundColor(.secondary)

                                    Image(systemName: "lock.fill")

                                        .foregroundColor(.secondary)

                                }

                            }

                        }

                        TextField("메모 선택", text: $memo)
                    }

                    Section("스코어 JPG") {
                        PhotosPicker(selection: $selectedPhoto, matching: .images) {
                            Text("스코어 이미지 추가/변경")
                        }

                        if scoreImageFileName != nil {
                            Button("스코어 보기") {
                                showScore = true
                            }

                            Button("스코어 이미지 삭제") {
                                scoreImageFileName = nil
                            }
                            .foregroundColor(.red)
                        }
                    }
                } else {
                    Section("불가능 사유") {
                        TextField("메모 선택", text: $memo)
                    }
                }

                if let event = editingEvent {
                    Section {
                        Button("일정 삭제") {
                            store.delete(event)
                            dismiss()
                        }
                        .foregroundColor(.red)
                    }
                }
            }
            .navigationTitle("일정 편집")
            .navigationBarTitleDisplayMode(.inline)
            .toolbar {
                ToolbarItem(placement: .navigationBarTrailing) {
                    Button {
                        if store.revealPrivateInfo {
                            store.revealPrivateInfo = false
                        } else {
                            authenticateToReveal { success in
                                if success {
                                    store.revealPrivateInfo = true
                                }
                            }
                        }
                    } label: {
                        Image(
                            systemName:
                                store.revealPrivateInfo
                            ? "lock.open.fill"
                            : "lock.fill"
                        )
                    }
                }

                ToolbarItem(placement: .confirmationAction) {
                    Button("저장") {
                        save()
                    }
                }
            }
            .onAppear {
                loadEvent()
            }
            .onChange(of: selectedPhoto) { _, newItem in
                Task {
                    if let data = try? await newItem?.loadTransferable(type: Data.self),
                       let fileName = store.saveScoreImage(data) {
                        scoreImageFileName = fileName
                    }
                }
            }
            .sheet(isPresented: $showScore) {
                if let fileName = scoreImageFileName {
                    ScoreImageView(imageURL: store.imageURL(fileName: fileName))
                } else {
                    Text("스코어 이미지가 없습니다.")
                }
            }
        }
    }

    func loadEvent() {
        if let event = store.event(on: date) {
            editingEvent = event
            course = event.course
            partners = event.partners
            memo = event.memo
            status = event.status
            scoreImageFileName = event.scoreImageFileName
            calendarEventID = event.calendarEventID
        } else {
            editingEvent = nil
            course = ""
            partners = ""
            memo = ""
            status = .golf
            scoreImageFileName = nil
            calendarEventID = nil
        }
    }

    func save() {
        let event = GolfEvent(
            id: editingEvent?.id ?? UUID(),
            date: date,
            course: status == .golf ? course : "",
            partners: status == .golf ? partners : "",
            memo: memo,
            status: status,
            scoreImageFileName: status == .golf ? scoreImageFileName : nil,
            calendarEventID: calendarEventID
        )

        let syncedEvent = CalendarManager.syncGolfEvent(event)
        store.upsert(syncedEvent)
        dismiss()
    }

    func dateText(_ date: Date) -> String {
        let formatter = DateFormatter()
        formatter.locale = Locale(identifier: "ko_KR")
        formatter.dateFormat = "yyyy년 M월 d일 EEEE"
        return formatter.string(from: date)
    }
}

struct ScoreImageView: View {
    let imageURL: URL

    var body: some View {
        NavigationStack {
            GeometryReader { geometry in
                ZStack {
                    Color.black.ignoresSafeArea()

                    if let uiImage = UIImage(contentsOfFile: imageURL.path) {
                        Image(uiImage: uiImage)
                            .resizable()
                            .scaledToFit()
                            .frame(
                                width: geometry.size.width,
                                height: geometry.size.height
                            )
                    } else {
                        Text("이미지를 불러올 수 없습니다.")
                            .foregroundColor(.white)
                    }
                }
            }
            .navigationTitle("스코어")
            .navigationBarTitleDisplayMode(.inline)
        }
    }
}

func maskedPartnerNames(_ text: String, revealed: Bool) -> String {
    if revealed {
        return text
    }

    let names = text
        .split(separator: ",")
        .map { String($0).trimmingCharacters(in: .whitespacesAndNewlines) }

    return names.map { maskName($0) }.joined(separator: ", ")
}

func maskName(_ name: String) -> String {
    let chars = Array(name)

    if chars.count <= 1 {
        return name
    } else if chars.count == 2 {
        return "\(chars[0])*"
    } else {
        var masked = chars
        masked[1] = "*"
        return String(masked)
    }
}

// MARK: - Round List

func authenticateToReveal(completion: @escaping (Bool) -> Void) {
    let context = LAContext()
    var error: NSError?

    if context.canEvaluatePolicy(.deviceOwnerAuthentication, error: &error) {
        context.evaluatePolicy(
            .deviceOwnerAuthentication,
            localizedReason: "동반자 이름 전체를 보려면 인증이 필요합니다."
        ) { success, _ in
            DispatchQueue.main.async {
                completion(success)
            }
        }
    } else {
        completion(false)
    }
}

