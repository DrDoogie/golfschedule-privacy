struct RoundListYearPageView: View {
    @EnvironmentObject var store: GolfStore

    let year: Int

    @State private var selectedEvent: GolfEvent?

    var golfEvents: [GolfEvent] {
        store.events
            .filter {
                $0.status == .golf &&
                Calendar.current.component(.year, from: $0.date) == year
            }
            .sorted { $0.date < $1.date }
    }

    var body: some View {
        Group {
            if golfEvents.isEmpty {
                VStack {
                    Spacer()
                    Text("라운딩 기록이 없습니다.")
                        .foregroundColor(.gray)
                    Spacer()
                }
            } else {
                List {
                    Section {
                        Button(
                            store.revealPrivateInfo
                            ? "동반자 이름 숨기기"
                            : "동반자 이름 전체 보기"
                        ) {
                            if store.revealPrivateInfo {
                                store.revealPrivateInfo = false
                            } else {
                                authenticateToReveal { success in
                                    if success {
                                        store.revealPrivateInfo = true
                                    }
                                }
                            }
                        }
                    }

                    ForEach(golfEvents) { event in
                        VStack(alignment: .leading, spacing: 6) {
                            Text(event.course)
                                .font(.headline)

                            Text(dateText(event.date))
                                .font(.subheadline)
                                .foregroundColor(.gray)

                            if !event.partners.isEmpty {
                                Text("동반자: \(maskedPartnerNames(event.partners, revealed: store.revealPrivateInfo))")
                                    .font(.subheadline)
                            }

                            if !event.memo.isEmpty {
                                Text("메모: \(event.memo)")
                                    .font(.caption)
                                    .foregroundColor(.gray)
                            }

                            if event.scoreImageFileName != nil {
                                Text("스코어 이미지 있음")
                                    .font(.caption)
                                    .foregroundColor(.green)
                            }

                            if event.calendarEventID != nil {
                                Text("Apple 캘린더 동기화됨")
                                    .font(.caption)
                                    .foregroundColor(.blue)
                            }
                        }
                        .padding(.vertical, 4)
                        .contentShape(Rectangle())
                        .onTapGesture {
                            selectedEvent = event
                        }
                    }
                    .onDelete(perform: delete)
                }
            }
        }
        .sheet(item: $selectedEvent) { event in
            EventEditorPagerView(initialDate: event.date)
                .environmentObject(store)
        }
    }

    func delete(at offsets: IndexSet) {
        let selected = offsets.map { golfEvents[$0] }
        selected.forEach { store.delete($0) }
    }

    func dateText(_ date: Date) -> String {
        let formatter = DateFormatter()
        formatter.locale = Locale(identifier: "ko_KR")
        formatter.dateFormat = "yyyy년 M월 d일"
        return formatter.string(from: date)
    }
}

// MARK: - Stats

struct StatsView: View {
    @EnvironmentObject var store: GolfStore
    @State private var selectedYear = Calendar.current.component(.year, from: Date())

    var body: some View {
        NavigationStack {
            VStack(spacing: 0) {
                HStack {
                    Button {
                        withAnimation {
                            selectedYear -= 1
                        }
                    } label: {
                        Image(systemName: "chevron.left")
                            .font(.title2)
                    }

                    Spacer()

                    Text(String(selectedYear) + "년")
                        .font(.title2)
                        .fontWeight(.bold)

                    Spacer()

                    Button {
                        withAnimation {
                            selectedYear += 1
                        }
                    } label: {
                        Image(systemName: "chevron.right")
                            .font(.title2)
                    }
                }
                .padding(.horizontal)
                .padding(.vertical, 8)

                TabView(selection: $selectedYear) {
                    ForEach(2000...2050, id: \.self) { year in
                        StatsYearPageView(year: year)
                            .environmentObject(store)
                            .tag(year)
                    }
                }
                .tabViewStyle(.page(indexDisplayMode: .never))
            }
            .navigationTitle("통계")
            .toolbar {
                ToolbarItem(placement: .navigationBarTrailing) {
                    Button {
                        if store.revealPrivateInfo {
                            store.revealPrivateInfo = false
                        } else {
                            authenticateToReveal { success in
                                if success {
                                    store.revealPrivateInfo = true
                                }
                            }
                        }
                    } label: {
                        Image(
                            systemName:
                                store.revealPrivateInfo
                            ? "lock.open.fill"
                            : "lock.fill"
                        )
                    }
                }
            }
        }
    }
}

struct StatsYearPageView: View {
    @EnvironmentObject var store: GolfStore

    let year: Int

    var golfEvents: [GolfEvent] {
        store.events.filter {
            $0.status == .golf
        }
    }

    var yearEvents: [GolfEvent] {
        golfEvents.filter {
            Calendar.current.component(.year, from: $0.date) == year
        }
    }

    var pastYearEvents: [GolfEvent] {
        yearEvents.filter {
            $0.date < Date()
        }
    }

    var futureYearEvents: [GolfEvent] {
        yearEvents.filter {
            $0.date >= Calendar.current.startOfDay(for: Date())
        }
    }

    var body: some View {
        List {
            Section("라운딩 횟수") {
                HStack {
                    Text("전체")
                    Spacer()
                    Text("\(yearEvents.count)회")
                }

                HStack {
                    Text("과거")
                    Spacer()
                    Text("\(pastYearEvents.count)회")
                }

                HStack {
                    Text("예정")
                    Spacer()
                    Text("\(futureYearEvents.count)회")
                }
            }

            Section("자주 가는 골프장") {
                if rankCourses().isEmpty {
                    Text("데이터 없음")
                        .foregroundColor(.gray)
                } else {
                    ForEach(rankCourses(), id: \.0) { item in
                        HStack {
                            Text(item.0)

                            Spacer()

                            Text("\(item.1)회")
                        }
                    }
                }
            }

            Section("자주 함께 하는 동반자") {
                if rankPartners().isEmpty {
                    Text("데이터 없음")
                        .foregroundColor(.gray)
                } else {
                    ForEach(rankPartners(), id: \.0) { item in
                        HStack {
                            Text(
                                maskedPartnerNames(
                                    item.0,
                                    revealed: store.revealPrivateInfo
                                )
                            )

                            Spacer()

                            Text("\(item.1)회")
                        }
                    }
                }
            }
        }
    }

    func rankCourses() -> [(String, Int)] {
        let names = yearEvents.map { $0.course }.filter { !$0.isEmpty }

        return Dictionary(grouping: names, by: { $0 })
            .map { ($0.key, $0.value.count) }
            .sorted { $0.1 > $1.1 }
    }

    func rankPartners() -> [(String, Int)] {
        let partners = yearEvents.flatMap {
            $0.partners
                .split(separator: ",")
                .map { $0.trimmingCharacters(in: .whitespacesAndNewlines) }
                .filter { !$0.isEmpty }
        }

        return Dictionary(grouping: partners, by: { $0 })
            .map { ($0.key, $0.value.count) }
            .sorted { $0.1 > $1.1 }
    }
}

// MARK: - Backup

struct BackupView: View {
    @EnvironmentObject var store: GolfStore

    @State private var showExporter = false
    @State private var showImporter = false

    var body: some View {
        NavigationStack {
            VStack(spacing: 20) {
                Text("데이터 백업 / 가져오기")
                    .font(.title2)
                    .fontWeight(.bold)

                Button("백업 파일 만들기") {
                    showExporter = true
                }
                .buttonStyle(.borderedProminent)

                Button("백업 파일 가져오기") {
                    showImporter = true
                }
                .buttonStyle(.bordered)

                Text("라운딩 일정은 JSON 파일로 백업됩니다. 스코어 이미지는 앱 내부 저장소에 보관됩니다.")
                    .font(.caption)
                    .foregroundColor(.gray)
                    .padding()

                Spacer()
            }
            .padding()
            .navigationTitle("백업")
            .fileExporter(
                isPresented: $showExporter,
                document: BackupDocument(data: store.backupData()),
                contentType: .json,
                defaultFilename: "GolfScheduleBackup"
            ) { result in
                print(result)
            }
            .fileImporter(
                isPresented: $showImporter,
                allowedContentTypes: [.json]
            ) { result in
                switch result {
                case .success(let url):
                    if url.startAccessingSecurityScopedResource() {
                        defer {
                            url.stopAccessingSecurityScopedResource()
                        }

                        if let data = try? Data(contentsOf: url) {
                            store.importBackup(data)
                        }
                    }

                case .failure:
                    print("Import failed")
                }
            }
        }
    }
}

