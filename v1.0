import SwiftUI
import Combine
import PhotosUI
import UniformTypeIdentifiers
import UIKit
import LocalAuthentication
import EventKit

enum DayStatus: String, Codable {
    case golf
    case unavailable
}

struct DateSelection: Identifiable {
    let id = UUID()
    let date: Date
}

struct GolfEvent: Identifiable, Codable {
    var id: UUID
    var date: Date
    var course: String
    var partners: String
    var memo: String
    var status: DayStatus
    var scoreImageFileName: String?
    var calendarEventID: String?

    init(
        id: UUID = UUID(),
        date: Date,
        course: String,
        partners: String,
        memo: String,
        status: DayStatus,
        scoreImageFileName: String? = nil,
        calendarEventID: String? = nil
    ) {
        self.id = id
        self.date = date
        self.course = course
        self.partners = partners
        self.memo = memo
        self.status = status
        self.scoreImageFileName = scoreImageFileName
        self.calendarEventID = calendarEventID
    }

    enum CodingKeys: String, CodingKey {
        case id, date, course, partners, memo, status, scoreImageFileName, calendarEventID
    }

    init(from decoder: Decoder) throws {
        let container = try decoder.container(keyedBy: CodingKeys.self)

        id = try container.decodeIfPresent(UUID.self, forKey: .id) ?? UUID()
        date = try container.decode(Date.self, forKey: .date)
        course = try container.decodeIfPresent(String.self, forKey: .course) ?? ""
        partners = try container.decodeIfPresent(String.self, forKey: .partners) ?? ""
        memo = try container.decodeIfPresent(String.self, forKey: .memo) ?? ""
        status = try container.decodeIfPresent(DayStatus.self, forKey: .status) ?? .golf
        scoreImageFileName = try container.decodeIfPresent(String.self, forKey: .scoreImageFileName)
        calendarEventID = try container.decodeIfPresent(String.self, forKey: .calendarEventID)
    }
}

// MARK: - Apple Calendar Manager

class CalendarManager {
    static let eventStore = EKEventStore()

    static func requestAccess() {

        let status = EKEventStore.authorizationStatus(for: .event)

        print("Calendar authorization status:", status.rawValue)

        if #available(iOS 17.0, *) {

            eventStore.requestFullAccessToEvents { granted, error in

                DispatchQueue.main.async {

                    if granted {

                        print("Apple Calendar full access granted")

                    } else {

                        print("Apple Calendar full access denied:", error?.localizedDescription ?? "no error")

                    }

                }

            }

        } else {

            eventStore.requestAccess(to: .event) { granted, error in

                DispatchQueue.main.async {

                    if granted {

                        print("Apple Calendar access granted")

                    } else {

                        print("Apple Calendar access denied:", error?.localizedDescription ?? "no error")

                    }

                }

            }

        }

    }

    static func syncGolfEvent(_ event: GolfEvent) -> GolfEvent {
        var updatedEvent = event

        if event.status != .golf {
            if let calendarEventID = event.calendarEventID {
                deleteCalendarEvent(calendarEventID)
            }
            updatedEvent.calendarEventID = nil
            return updatedEvent
        }

        if let calendarEventID = event.calendarEventID,
           let calendarEvent = eventStore.event(withIdentifier: calendarEventID) {
            applyGolfInfo(to: calendarEvent, from: event)

            do {
                try eventStore.save(calendarEvent, span: .thisEvent)
                updatedEvent.calendarEventID = calendarEvent.eventIdentifier
            } catch {
                print("Calendar update failed:", error)
            }

            return updatedEvent
        }

        let calendarEvent = EKEvent(eventStore: eventStore)
        applyGolfInfo(to: calendarEvent, from: event)
        calendarEvent.calendar = eventStore.defaultCalendarForNewEvents

        do {
            try eventStore.save(calendarEvent, span: .thisEvent)
            updatedEvent.calendarEventID = calendarEvent.eventIdentifier
        } catch {
            print("Calendar create failed:", error)
        }

        return updatedEvent
    }

    static func deleteCalendarEvent(_ calendarEventID: String) {
        guard let calendarEvent = eventStore.event(withIdentifier: calendarEventID) else {
            return
        }

        do {
            try eventStore.remove(calendarEvent, span: .thisEvent)
        } catch {
            print("Calendar delete failed:", error)
        }
    }

    private static func applyGolfInfo(to calendarEvent: EKEvent, from golfEvent: GolfEvent) {
        let calendar = Calendar.current
        let startOfDay = calendar.startOfDay(for: golfEvent.date)
        let endOfDay = calendar.date(byAdding: .day, value: 1, to: startOfDay) ?? golfEvent.date

        let courseTitle = golfEvent.course.isEmpty ? "골프 라운딩" : golfEvent.course

        calendarEvent.title = "⛳️ \(courseTitle)"
        calendarEvent.startDate = startOfDay
        calendarEvent.endDate = endOfDay
        calendarEvent.isAllDay = true

        var notes = "GolfScheduleApp에서 생성한 일정입니다."

        if !golfEvent.memo.isEmpty {
            notes += "\n\n메모: \(golfEvent.memo)"
        }

        calendarEvent.notes = notes
    }
}

class GolfStore: ObservableObject {
    //let objectWillChange: ObservableObjectPublisher
    @Published var revealPrivateInfo = false
    @Published var events: [GolfEvent] = GolfStore.loadEvents()

    private static let key = "golf_events_local_only"

    static func loadEvents() -> [GolfEvent] {
        guard let data = UserDefaults.standard.data(forKey: key) else {
            return []
        }

        do {
            return try JSONDecoder().decode([GolfEvent].self, from: data)
        } catch {
            print("Load failed:", error)
            return []
        }
    }

    func save() {
        do {
            let data = try JSONEncoder().encode(events)
            UserDefaults.standard.set(data, forKey: GolfStore.key)
        } catch {
            print("Save failed:", error)
        }
    }

    func event(on date: Date) -> GolfEvent? {
        events.first {
            Calendar.current.isDate($0.date, inSameDayAs: date)
        }
    }

    func upsert(_ event: GolfEvent) {
        if let index = events.firstIndex(where: { $0.id == event.id }) {
            events[index] = event
        } else {
            events.append(event)
        }
        save()
    }

    func delete(_ event: GolfEvent) {
        if let calendarEventID = event.calendarEventID {
            CalendarManager.deleteCalendarEvent(calendarEventID)
        }

        events.removeAll { $0.id == event.id }
        save()
    }

    func backupData() -> Data {
        do {
            return try JSONEncoder().encode(events)
        } catch {
            return Data()
        }
    }

    func importBackup(_ data: Data) {
        do {
            events = try JSONDecoder().decode([GolfEvent].self, from: data)
            save()
        } catch {
            print("Import failed:", error)
        }
    }

    func saveScoreImage(_ data: Data) -> String? {
        let fileName = UUID().uuidString + ".jpg"
        let url = documentsURL().appendingPathComponent(fileName)

        do {
            try data.write(to: url)
            return fileName
        } catch {
            print("Image save failed:", error)
            return nil
        }
    }

    func imageURL(fileName: String) -> URL {
        documentsURL().appendingPathComponent(fileName)
    }

    private func documentsURL() -> URL {
        FileManager.default.urls(for: .documentDirectory, in: .userDomainMask)[0]
    }
}

struct BackupDocument: FileDocument {
    static var readableContentTypes: [UTType] {
        [.json]
    }

    var data: Data

    init(data: Data) {
        self.data = data
    }

    init(configuration: ReadConfiguration) throws {
        self.data = configuration.file.regularFileContents ?? Data()
    }

    func fileWrapper(configuration: WriteConfiguration) throws -> FileWrapper {
        FileWrapper(regularFileWithContents: data)
    }
}

