                }

            StatsView()
                .environmentObject(store)
                .tabItem {
                    Label("통계", systemImage: "chart.bar")
                }

            BackupView()
                .environmentObject(store)
                .tabItem {
                    Label("백업", systemImage: "externaldrive")
                }
