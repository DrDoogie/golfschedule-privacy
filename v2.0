struct RoundEditorPagerView: View {
    let initialDate: Date

    @State private var dayIndex = 0

    var body: some View {
        TabView(selection: $dayIndex) {
            ForEach(-365...365, id: \.self) { index in
                RoundEditorView(
                    date: Calendar.current.date(byAdding: .day, value: index, to: initialDate) ?? initialDate
                )
                .tag(index)
            }
        }
        .tabViewStyle(.page(indexDisplayMode: .never))
    }
}

struct RoundEditorView: View {
    @EnvironmentObject var store: GolfRoundStore
    @Environment(\.dismiss) var dismiss

    let date: Date

    @State private var course = ""
    @State private var partners: [String] = []
    @State private var newPartnerName = ""
    @State private var memo = ""
    @State private var status: RoundStatus = .round
    @State private var scores: [PlayerScore] = []
    @State private var editingRound: GolfRound?
    @State private var selectedPhoto: PhotosPickerItem?
    @State private var scoreImageFileName: String?
    @State private var calendarEventID: String?
    @State private var showScoreImage = false
    @State private var useTeeTime = false
    @State private var teeTime = Date()

    var body: some View {
        NavigationStack {
            Form {
                Section(text("date", store.language)) {
                    Text(dateText(date))
                }

                Section(text("schedule_type", store.language)) {
                    Picker(text("schedule_type", store.language), selection: $status) {
                        Text(text("golf_round", store.language)).tag(RoundStatus.round)
                        Text(text("unavailable", store.language)).tag(RoundStatus.unavailable)
                    }
                    .pickerStyle(.segmented)
                }

                if status == .round {
                    roundInfoSection
                    teeTimeSection
                    mapSection
                    partnersSection
                    scoresSection
                    scoreImageSection
                } else {
                    Section(text("memo", store.language)) {
                        TextField(text("memo", store.language), text: $memo)
                    }
                }

                if let round = editingRound {
                    Section {
                        Button(text("delete_round", store.language)) {
                            store.delete(round)
                            dismiss()
                        }
                        .foregroundColor(.red)
                    }
                }
            }
            .navigationTitle(text("round_editor", store.language))
            .navigationBarTitleDisplayMode(.inline)
            .toolbar {
                ToolbarItem(placement: .navigationBarTrailing) {
                    Button {
                        togglePrivacy()
                    } label: {
                        Image(systemName: store.revealPrivateInfo ? "lock.open.fill" : "lock.fill")
                    }
                }

                ToolbarItem(placement: .confirmationAction) {
                    Button(text("save", store.language)) {
                        save()
                    }
                }
            }
            .onAppear {
                loadRound()
            }
            .onChange(of: selectedPhoto) { _, newItem in
                Task {
                    if let data = try? await newItem?.loadTransferable(type: Data.self),
                       let fileName = store.saveScoreImage(data) {
                        scoreImageFileName = fileName
                    }
                }
            }
            .sheet(isPresented: $showScoreImage) {
                if let fileName = scoreImageFileName {
                    ScoreImageView(imageURL: store.imageURL(fileName: fileName), lang: store.language)
                } else {
                    Text(text("no_score_data", store.language))
                }
            }
        }
    }

    var roundInfoSection: some View {
        Section(text("round_info", store.language)) {
            TextField(text("course", store.language), text: $course)
            TextField(text("memo", store.language), text: $memo)
        }
    }

    var teeTimeSection: some View {
        Section(text("tee_time", store.language)) {
            Toggle(text("use_tee_time", store.language), isOn: $useTeeTime)

            if useTeeTime {
                DatePicker(
                    text("tee_time", store.language),
                    selection: $teeTime,
                    displayedComponents: .hourAndMinute
                )
            }
        }
    }

    var mapSection: some View {
        Section(text("map", store.language)) {
            Button(text("open_google_maps", store.language)) {
                openGoogleMaps(course: course, lang: store.language)
            }
            .disabled(course.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty)

            Button(text("nearby_restaurants", store.language)) {
                openNearbyRestaurants(course: course, lang: store.language)
            }
            .disabled(course.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty)
        }
    }

    var partnersSection: some View {
        Section(text("partners", store.language)) {
            if partners.isEmpty {
                Text(text("no_partners", store.language))
                    .foregroundColor(.secondary)
            }

            ForEach(partners.indices, id: \.self) { index in
                HStack {
                    if store.revealPrivateInfo {
                        TextField(
                            text("partner_name", store.language),
                            text: Binding(
                                get: {
                                    if partners.indices.contains(index) {
                                        return partners[index]
                                    }
                                    return ""
                                },
                                set: { newValue in
                                    if partners.indices.contains(index) {
                                        partners[index] = newValue
                                        syncScoreListWithPlayers()
                                    }
                                }
                            )
                        )
                    } else {
                        Text(maskName(partners[index]))
                            .foregroundColor(.secondary)
                    }

                    Spacer()

                    Button {
                        removePartner(at: index)
                    } label: {
                        Image(systemName: "minus.circle.fill")
                            .foregroundColor(.red)
                    }
                    .buttonStyle(.plain)
                }
            }

            HStack {
                TextField(text("add_partner", store.language), text: $newPartnerName)

                Button {
                    addPartner()
                } label: {
                    Image(systemName: "plus.circle.fill")
                }
                .disabled(newPartnerName.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty)
            }
        }
    }

    var scoresSection: some View {
        Section(text("scores_ranking", store.language)) {
            Button(text("build_score_list", store.language)) {
                syncScoreListWithPlayers()
            }

            if scores.isEmpty {
                Text(text("no_scores", store.language))
                    .foregroundColor(.secondary)
            }

            ForEach($scores) { $score in
                HStack {
                    Text(displayName(score.name, isMe: score.isMe))
                        .frame(minWidth: 100, alignment: .leading)

                    Spacer()

                    TextField(text("score", store.language), value: $score.score, format: .number)
                        .keyboardType(.numberPad)
                        .multilineTextAlignment(.trailing)
                        .frame(width: 70)

                    if score.isMe {
                        Text(text("me", store.language))
                            .font(.caption)
                            .foregroundColor(.blue)
                    }
                }
            }

            if !rankedScores().isEmpty {
                Text(text("round_ranking", store.language))
                    .font(.caption)
                    .foregroundColor(.secondary)
                    .padding(.top, 4)

                ForEach(rankedScores()) { item in
                    HStack {
                        Text(rankOf(item))
                            .frame(width: 35, alignment: .leading)

                        Text(displayName(item.name, isMe: item.isMe))

                        Spacer()

                        Text("\(item.score)")
                    }
                }

                if let myRank = myRankText() {
                    Text(myRank)
                        .font(.headline)
                        .foregroundColor(.blue)
                }
            }
        }
    }

    var scoreImageSection: some View {
        Section(text("score_image", store.language)) {
            PhotosPicker(selection: $selectedPhoto, matching: .images) {
                Text(text("add_score_image", store.language))
            }

            if scoreImageFileName != nil {
                Button(text("view_score_image", store.language)) {
                    showScoreImage = true
                }

                Button(text("delete_score_image", store.language)) {
                    scoreImageFileName = nil
                }
                .foregroundColor(.red)
            }
        }
    }
}

// ======================================================
// SECTION 08 / Editor Functions
// ======================================================

extension RoundEditorView {
    func loadRound() {
        if let round = store.round(on: date) {
            editingRound = round
            course = round.course
            partners = round.partners
            memo = round.memo
            status = round.status
            scores = round.scores
            scoreImageFileName = round.scoreImageFileName
            calendarEventID = round.calendarEventID

            if let savedTeeTime = round.teeTime {
                useTeeTime = true
                teeTime = savedTeeTime
            } else {
                useTeeTime = false
                teeTime = Date()
            }
        } else {
            editingRound = nil
            course = ""
            partners = []
            memo = ""
            status = .round
            scores = []
            scoreImageFileName = nil
            calendarEventID = nil
            useTeeTime = false
            teeTime = Date()
        }

        syncScoreListWithPlayers()
    }

    func addPartner() {
        let name = newPartnerName.trimmingCharacters(in: .whitespacesAndNewlines)
        guard !name.isEmpty else { return }

        if !partners.contains(name) {
            partners.append(name)
        }

        newPartnerName = ""
        syncScoreListWithPlayers()
    }

    func removePartner(at index: Int) {
        guard partners.indices.contains(index) else { return }

        let name = partners[index]
        partners.remove(at: index)
        scores.removeAll { $0.name == name && !$0.isMe }

        syncScoreListWithPlayers()
    }

    func syncScoreListWithPlayers() {
        let trimmedMyName = store.myName.trimmingCharacters(in: .whitespacesAndNewlines)
        let myDisplayName = trimmedMyName.isEmpty ? text("me", store.language) : trimmedMyName

        if let myIndex = scores.firstIndex(where: { $0.isMe }) {
            scores[myIndex].name = myDisplayName
        } else {
            scores.insert(
                PlayerScore(name: myDisplayName, score: 0, isMe: true),
                at: 0
            )
        }

        let validPartners = partners
            .map { $0.trimmingCharacters(in: .whitespacesAndNewlines) }
            .filter { !$0.isEmpty }

        var newScores: [PlayerScore] = []

        if let me = scores.first(where: { $0.isMe }) {
            newScores.append(me)
        }

        for partner in validPartners {
            if let existing = scores.first(where: { !$0.isMe && $0.name == partner }) {
                newScores.append(existing)
            } else {
                newScores.append(PlayerScore(name: partner, score: 0, isMe: false))
            }
        }

        scores = newScores
    }

    func rankedScores() -> [PlayerScore] {
        scores
            .filter { $0.score > 0 }
            .sorted { $0.score < $1.score }
    }

    func rankOf(_ score: PlayerScore) -> String {
        let ranked = rankedScores()

        guard let index = ranked.firstIndex(where: { $0.id == score.id }) else {
            return "-"
        }

        return "#\(index + 1)"
    }

    func myRankText() -> String? {
        let ranked = rankedScores()

        guard let index = ranked.firstIndex(where: { $0.isMe }) else {
            return nil
        }

        return "\(text("my_rank", store.language)): #\(index + 1) / \(ranked.count)"
    }

    func displayName(_ name: String, isMe: Bool) -> String {
        if isMe {
            return name
        }

        return store.revealPrivateInfo ? name : maskName(name)
    }

    func save() {
        syncScoreListWithPlayers()

        let round = GolfRound(
            id: editingRound?.id ?? UUID(),
            date: date,
            course: status == .round ? course : "",
            partners: status == .round ? partners : [],
            memo: memo,
            status: status,
            scores: status == .round ? scores : [],
            scoreImageFileName: status == .round ? scoreImageFileName : nil,
            calendarEventID: calendarEventID,
            teeTime: status == .round && useTeeTime ? teeTime : nil
        )

        let synced = CalendarManager.sync(round, lang: store.language)
        store.upsert(synced)
        dismiss()
    }

    func togglePrivacy() {
        if store.revealPrivateInfo {
            store.revealPrivateInfo = false
        } else {
            authenticateToReveal { success in
                if success {
                    store.revealPrivateInfo = true
                }
            }
        }
    }

    func dateText(_ date: Date) -> String {
        let formatter = DateFormatter()
        formatter.locale = store.language == .korean ? Locale(identifier: "ko_KR") : Locale(identifier: "en_US")
        formatter.dateFormat = store.language == .korean ? "yyyy년 M월 d일 EEEE" : "MMM d, yyyy EEEE"
        return formatter.string(from: date)
    }
}

