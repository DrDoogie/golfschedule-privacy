// SECTION 07 / Editor Pager & Editor Main
// ======================================================

struct RoundEditorPagerView: View {
    let initialDate: Date

    @State private var dayIndex = 0

    var body: some View {
        TabView(selection: $dayIndex) {
            ForEach(-365...365, id: \.self) { index in
                RoundEditorView(
                    date: Calendar.current.date(byAdding: .day, value: index, to: initialDate) ?? initialDate
                )
                .tag(index)
            }
        }
        .tabViewStyle(.page(indexDisplayMode: .never))
    }
}

struct RoundEditorView: View {
    @EnvironmentObject var store: GolfRoundStore
    @Environment(\.dismiss) var dismiss

    let date: Date

    @State private var course = ""
    @State private var partners: [String] = []
    @State private var newPartnerName = ""
    @State private var memo = ""
    @State private var status: RoundStatus = .round
    @State private var scores: [PlayerScore] = []
    @State private var editingRound: GolfRound?
    @State private var selectedPhotos: [PhotosPickerItem] = []
    @State private var roundPhotoFileNames: [String] = []
    @State private var calendarEventID: String?
    @State private var showPhotoGallery = false
    @State private var useTeeTime = false
    @State private var teeTime = Date()

    var body: some View {
        NavigationStack {
            Form {
                Section(text("date", store.language)) {
                    Text(dateText(date))
                }

                Section(text("schedule_type", store.language)) {
                    Picker(text("schedule_type", store.language), selection: $status) {
                        Text(text("golf_round", store.language)).tag(RoundStatus.round)
                        Text(text("unavailable", store.language)).tag(RoundStatus.unavailable)
                    }
                    .pickerStyle(.segmented)
                }

                if status == .round {
                    roundInfoSection
                    teeTimeSection
                    mapSection
                    partnersSection
                    scoresSection
                    visualRankingSection
                    roundPhotosSection
                } else {
                    Section(text("memo", store.language)) {
                        TextField(text("memo", store.language), text: $memo)
                    }
                }

                if let round = editingRound {
                    Section {
                        Button(text("delete_round", store.language)) {
                            store.delete(round)
                            dismiss()
                        }
                        .foregroundColor(.red)
                    }
                }
            }
            .navigationTitle(text("round_editor", store.language))
            .navigationBarTitleDisplayMode(.inline)
            .toolbar {
                ToolbarItem(placement: .navigationBarTrailing) {
                    Button {
                        togglePrivacy()
                    } label: {
                        Image(systemName: store.revealPrivateInfo ? "lock.open.fill" : "lock.fill")
                    }
                }

                ToolbarItem(placement: .confirmationAction) {
                    Button(text("save", store.language)) {
                        save()
                    }
                }
            }
            .onAppear {
                loadRound()
            }
            .onChange(of: selectedPhotos) { _, newItems in
                Task {
                    for item in newItems {
                        if let data = try? await item.loadTransferable(type: Data.self),
                           let fileName = store.saveRoundPhoto(data) {
                            roundPhotoFileNames.append(fileName)
                        }
                    }

                    selectedPhotos = []
                }
            }
            .sheet(isPresented: $showPhotoGallery) {
                RoundPhotoGalleryView(
                    photoFileNames: $roundPhotoFileNames,
                    store: store
                )
            }
        }
    }

    var roundInfoSection: some View {
        Section(text("round_info", store.language)) {
            TextField(text("course", store.language), text: $course)
            TextField(text("memo", store.language), text: $memo)
        }
    }

    var teeTimeSection: some View {
        Section(text("tee_time", store.language)) {
            Toggle(text("use_tee_time", store.language), isOn: $useTeeTime)

            if useTeeTime {
                DatePicker(
                    text("tee_time", store.language),
                    selection: $teeTime,
                    displayedComponents: .hourAndMinute
                )
            }
        }
    }

    var mapSection: some View {
        Section(text("map", store.language)) {
            Button(text("open_google_maps", store.language)) {
                openGoogleMaps(course: course, lang: store.language)
            }
            .disabled(course.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty)

            Button(text("nearby_restaurants", store.language)) {
                openNearbyRestaurants(course: course, lang: store.language)
            }
            .disabled(course.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty)
        }
    }

    var partnersSection: some View {
        Section(text("partners", store.language)) {
            if partners.isEmpty {
                Text(text("no_partners", store.language))
                    .foregroundColor(.secondary)
            }

            ForEach(partners.indices, id: \.self) { index in
                HStack {
                    if store.revealPrivateInfo {
                        TextField(
                            text("partner_name", store.language),
                            text: Binding(
                                get: {
                                    partners.indices.contains(index) ? partners[index] : ""
                                },
                                set: { newValue in
                                    if partners.indices.contains(index) {
                                        partners[index] = newValue
                                        syncScoreListWithPlayers()
                                    }
                                }
                            )
                        )
                    } else {
                        Text(maskName(partners[index]))
                            .foregroundColor(.secondary)
                    }

                    Spacer()

                    Button {
                        removePartner(at: index)
                    } label: {
                        Image(systemName: "minus.circle.fill")
                            .foregroundColor(.red)
                    }
                    .buttonStyle(.plain)
                }
            }

            HStack {
                TextField(text("add_partner", store.language), text: $newPartnerName)

                Button {
                    addPartner()
                } label: {
                    Image(systemName: "plus.circle.fill")
                }
                .disabled(newPartnerName.trimmingCharacters(in: .whitespacesAndNewlines).isEmpty)
            }
        }
    }

    var scoresSection: some View {
        Section(text("scores_ranking", store.language)) {
            Button(text("refresh_score_list", store.language)) {
                syncScoreListWithPlayers()
            }

            if scores.isEmpty {
                Text(text("no_scores", store.language))
                    .foregroundColor(.secondary)
            }

            ForEach($scores) { $score in
                CompactScoreDialRow(
                    playerScore: $score,
                    lang: store.language,
                    revealPrivateInfo: store.revealPrivateInfo
                )
            }

            Text(store.language == .korean ? "미입력은 순위/통계에 포함되지 않습니다." : "Not entered scores are excluded from rankings and stats.")
                .font(.caption)
                .foregroundColor(.secondary)
        }
    }

    var visualRankingSection: some View {
        Section(text("round_ranking", store.language)) {
            if rankedScores().isEmpty {
                Text(text("no_score_data", store.language))
                    .foregroundColor(.gray)
            } else {
                VStack(spacing: 10) {
                    if let winner = rankedScores().first {
                        WinnerCard(
                            rankText: "#1",
                            name: displayName(winner.name, isMe: winner.isMe),
                            score: scoreText(winner.score),
                            isMe: winner.isMe
                        )
                    }

                    ForEach(Array(rankedScores().dropFirst().enumerated()), id: \.element.id) { index, item in
                        RankingCard(
                            rankText: "#\(index + 2)",
                            name: displayName(item.name, isMe: item.isMe),
                            score: scoreText(item.score),
                            isMe: item.isMe
                        )
                    }

                    if let myRank = myRankText() {
                        Text(myRank)
                            .font(.headline)
                            .foregroundColor(.blue)
                            .frame(maxWidth: .infinity, alignment: .center)
                    }
                }
                .padding(.vertical, 4)
            }
        }
    }

    var roundPhotosSection: some View {
        Section(text("round_photos", store.language)) {
            PhotosPicker(
                selection: $selectedPhotos,
                maxSelectionCount: 20,
                matching: .images
            ) {
                Text(text("add_round_photos", store.language))
            }

            if !roundPhotoFileNames.isEmpty {
                Button("\(text("view_round_photos", store.language)) (\(roundPhotoFileNames.count))") {
                    showPhotoGallery = true
                }
            }
        }
    }
}

struct CompactScoreDialRow: View {
    @Binding var playerScore: PlayerScore

    let lang: AppLanguage
    let revealPrivateInfo: Bool

    var body: some View {
        HStack(spacing: 10) {
            VStack(alignment: .leading, spacing: 2) {
                HStack(spacing: 5) {
                    Text(displayName)
                        .font(.headline)

                    if playerScore.isMe {
                        Text("ME")
                            .font(.caption2)
                            .fontWeight(.bold)
                            .foregroundColor(.blue)
                    }
                }
            }
            .frame(minWidth: 86, maxWidth: .infinity, alignment: .leading)

            ZStack {
                RoundedRectangle(cornerRadius: 9)
                    .fill(Color.blue.opacity(playerScore.score == nil ? 0.05 : 0.11))
                    .frame(width: 104, height: 38)

                HStack(spacing: 0) {
                    Rectangle()
                        .fill(Color.blue.opacity(playerScore.score == nil ? 0.45 : 1.0))
                        .frame(width: 2, height: 32)

                    Picker(
                        "",
                        selection: Binding<Int>(
                            get: {
                                playerScore.score ?? 90
                            },
                            set: { newValue in
                                playerScore.score = newValue
                            }
                        )
                    ) {
                        ForEach(50...150, id: \.self) { value in
                            Text("\(value)")
                                .font(.title3)
                                .fontWeight(.semibold)
                                .tag(value)
                        }
                    }
                    .pickerStyle(.wheel)
                    .frame(width: 78, height: 40)
                    .clipped()
                    .scaleEffect(0.72)
                    .opacity(playerScore.score == nil ? 0.6 : 1.0)

                    Rectangle()
                        .fill(Color.blue.opacity(playerScore.score == nil ? 0.45 : 1.0))
                        .frame(width: 2, height: 32)
                }
            }

            Button {
                playerScore.score = nil
            } label: {
                Text(lang == .korean ? "미입력" : "None")
                    .font(.caption2)
                    .fontWeight(.semibold)
                    .lineLimit(1)
                    .minimumScaleFactor(0.7)
                    .foregroundColor(.blue)
                    .frame(width: 52, height: 28)
                    .background(Color.gray.opacity(0.12))
                    .cornerRadius(8)
            }
            .buttonStyle(.borderless)
        }
        .padding(.vertical, 0)
    }

    var displayName: String {
        if playerScore.isMe {
            return playerScore.name
        }

        return revealPrivateInfo ? playerScore.name : maskName(playerScore.name)
    }
}

struct WinnerCard: View {
    let rankText: String
    let name: String
    let score: String
    let isMe: Bool

    var body: some View {
        VStack(spacing: 8) {
            Text("🏆")
                .font(.largeTitle)

            Text(rankText)
                .font(.caption)
                .foregroundColor(.secondary)

            Text(name)
                .font(.title3)
                .fontWeight(.bold)

            Text(score)
                .font(.title)
                .fontWeight(.heavy)

            if isMe {
                Text("ME")
                    .font(.caption)
                    .fontWeight(.bold)
                    .foregroundColor(.blue)
            }
        }
        .frame(maxWidth: .infinity)
        .padding()
        .background(Color.yellow.opacity(0.18))
        .cornerRadius(16)
    }
}

struct RankingCard: View {
    let rankText: String
    let name: String
    let score: String
    let isMe: Bool

    var body: some View {
        HStack(spacing: 12) {
            Text(rankEmoji)
                .font(.title2)
                .frame(width: 34)

            VStack(alignment: .leading, spacing: 4) {
                Text(rankText)
                    .font(.caption)
                    .foregroundColor(.secondary)

                HStack {
                    Text(name)
                        .font(.headline)

                    if isMe {
                        Text("ME")
                            .font(.caption)
                            .fontWeight(.bold)
                            .foregroundColor(.blue)
                    }
                }
            }

            Spacer()

            Text(score)
                .font(.title3)
                .fontWeight(.bold)
        }
        .padding()
        .background(Color.gray.opacity(0.08))
        .cornerRadius(14)
    }

    var rankEmoji: String {
        if rankText == "#2" {
            return "🥈"
        } else if rankText == "#3" {
            return "🥉"
        } else {
            return "⛳️"
        }
    }
}


// ======================================================
// SECTION 08 / Editor Functions
// ======================================================

extension RoundEditorView {
    func loadRound() {
        if let round = store.round(on: date) {
            editingRound = round
            course = round.course
            partners = round.partners
            memo = round.memo
            status = round.status
            scores = round.scores
            roundPhotoFileNames = round.roundPhotoFileNames
            calendarEventID = round.calendarEventID

            if let savedTeeTime = round.teeTime {
                useTeeTime = true
                teeTime = savedTeeTime
            } else {
                useTeeTime = false
                teeTime = Date()
            }
        } else {
            editingRound = nil
            course = ""
            partners = []
            memo = ""
            status = .round
            scores = []
            roundPhotoFileNames = []
            calendarEventID = nil
            useTeeTime = false
            teeTime = Date()
        }

        syncScoreListWithPlayers()
    }

    func addPartner() {
        let name = newPartnerName.trimmingCharacters(in: .whitespacesAndNewlines)
        guard !name.isEmpty else { return }
        if !partners.contains(name) { partners.append(name) }
        newPartnerName = ""
        syncScoreListWithPlayers()
    }

    func removePartner(at index: Int) {
        guard partners.indices.contains(index) else { return }
        let name = partners[index]
        partners.remove(at: index)
        scores.removeAll { $0.name == name && !$0.isMe }
        syncScoreListWithPlayers()
    }

    func syncScoreListWithPlayers() {
        let trimmedMyName = store.myName.trimmingCharacters(in: .whitespacesAndNewlines)
        let myDisplayName = trimmedMyName.isEmpty ? text("me", store.language) : trimmedMyName

        if let myIndex = scores.firstIndex(where: { $0.isMe }) {
            scores[myIndex].name = myDisplayName
        } else {
            scores.insert(PlayerScore(name: myDisplayName, score: nil, isMe: true), at: 0)
        }

        let validPartners = partners
            .map { $0.trimmingCharacters(in: .whitespacesAndNewlines) }
            .filter { !$0.isEmpty }

        var newScores: [PlayerScore] = []

        if let me = scores.first(where: { $0.isMe }) {
            newScores.append(me)
        }

        for partner in validPartners {
            if let existing = scores.first(where: { !$0.isMe && $0.name == partner }) {
                newScores.append(existing)
            } else {
                newScores.append(PlayerScore(name: partner, score: nil, isMe: false))
            }
        }

        scores = newScores
    }

    func rankedScores() -> [PlayerScore] {
        scores
            .filter { $0.score != nil }
            .sorted { ($0.score ?? 999) < ($1.score ?? 999) }
    }

    func rankOf(_ score: PlayerScore) -> String {
        let ranked = rankedScores()
        guard let index = ranked.firstIndex(where: { $0.id == score.id }) else { return "-" }
        return "#\(index + 1)"
    }

    func myRankText() -> String? {
        let ranked = rankedScores()
        guard let index = ranked.firstIndex(where: { $0.isMe }) else { return nil }
        return "\(text("my_rank", store.language)): #\(index + 1) / \(ranked.count)"
    }

    func displayName(_ name: String, isMe: Bool) -> String {
        if isMe { return name }
        return store.revealPrivateInfo ? name : maskName(name)
    }

    func scoreText(_ score: Int?) -> String {
        if let score = score { return "\(score)" }
        return "--"
    }

    func save() {
        syncScoreListWithPlayers()

        let round = GolfRound(
            id: editingRound?.id ?? UUID(),
            date: date,
            course: status == .round ? course : "",
            partners: status == .round ? partners : [],
            memo: memo,
            status: status,
            scores: status == .round ? scores : [],
            roundPhotoFileNames: status == .round ? roundPhotoFileNames : [],
            calendarEventID: calendarEventID,
            teeTime: status == .round && useTeeTime ? teeTime : nil
        )

        let synced = CalendarManager.sync(round, lang: store.language)
        store.upsert(synced)
        dismiss()
    }

    func togglePrivacy() {
        if store.revealPrivateInfo {
            store.revealPrivateInfo = false
        } else {
            authenticateToReveal { success in
                if success { store.revealPrivateInfo = true }
            }
        }
    }

    func dateText(_ date: Date) -> String {
        let formatter = DateFormatter()
        formatter.locale = store.language == .korean ? Locale(identifier: "ko_KR") : Locale(identifier: "en_US")
        formatter.dateFormat = store.language == .korean ? "yyyy년 M월 d일 EEEE" : "MMM d, yyyy EEEE"
        return formatter.string(from: date)
    }
}

// ======================================================
// SECTION 09 / Round Photo Gallery & Round List
// ======================================================

struct RoundPhotoGalleryView: View {
    @Binding var photoFileNames: [String]

    @ObservedObject var store: GolfRoundStore
    @Environment(\.dismiss) var dismiss

    @State private var selectedIndex = 0
    @State private var showDeleteAlert = false

    var body: some View {
        NavigationStack {
            ZStack {
                Color.black.ignoresSafeArea()

                if photoFileNames.isEmpty {
                    Text(text("no_data", store.language))
                        .foregroundColor(.white)
                } else {
                    TabView(selection: $selectedIndex) {
                        ForEach(Array(photoFileNames.enumerated()), id: \.element) { index, fileName in
                            if let uiImage = loadImage(fileName: fileName) {
                                ZoomableImageScrollView(image: uiImage)
                                    .tag(index)
                                    .ignoresSafeArea()
                            } else {
                                Text(text("unable_load_image", store.language))
                                    .foregroundColor(.white)
                                    .tag(index)
                            }
                        }
                    }
                    .tabViewStyle(.page(indexDisplayMode: .automatic))
                }
            }
            .navigationTitle(photoTitle)
            .navigationBarTitleDisplayMode(.inline)
            .toolbar {
                ToolbarItem(placement: .cancellationAction) {
                    Button(store.language == .korean ? "닫기" : "Close") {
                        dismiss()
                    }
                }

                ToolbarItem(placement: .navigationBarTrailing) {
                    if !photoFileNames.isEmpty {
                        Button {
                            showDeleteAlert = true
                        } label: {
                            Image(systemName: "trash")
                                .foregroundColor(.red)
                        }
                    }
                }
            }
            .alert(
                store.language == .korean ? "사진 삭제" : "Delete Photo",
                isPresented: $showDeleteAlert
            ) {
                Button(store.language == .korean ? "삭제" : "Delete", role: .destructive) {
                    deleteCurrentPhoto()
                }

                Button(store.language == .korean ? "취소" : "Cancel", role: .cancel) { }
            } message: {
                Text(store.language == .korean ? "현재 사진을 삭제할까요?" : "Delete this photo?")
            }
        }
    }

    var photoTitle: String {
        if photoFileNames.isEmpty {
            return text("round_photos", store.language)
        }

        return "\(text("round_photos", store.language)) \(selectedIndex + 1)/\(photoFileNames.count)"
    }

    func loadImage(fileName: String) -> UIImage? {
        let url = store.imageURL(fileName: fileName)

        if let image = UIImage(contentsOfFile: url.path) {
            return image
        }

        if let data = try? Data(contentsOf: url),
           let image = UIImage(data: data) {
            return image
        }

        return nil
    }

    func deleteCurrentPhoto() {
        guard photoFileNames.indices.contains(selectedIndex) else {
            return
        }

        let fileName = photoFileNames[selectedIndex]
        store.deleteRoundPhoto(fileName: fileName)
        photoFileNames.remove(at: selectedIndex)

        if selectedIndex >= photoFileNames.count {
            selectedIndex = max(photoFileNames.count - 1, 0)
        }
    }
}

struct ZoomableImageScrollView: UIViewRepresentable {
    let image: UIImage

    func makeUIView(context: Context) -> UIScrollView {
        let scrollView = UIScrollView()

        scrollView.delegate = context.coordinator
        scrollView.backgroundColor = .black
        scrollView.minimumZoomScale = 1.0
        scrollView.maximumZoomScale = 6.0
        scrollView.bouncesZoom = true
        scrollView.showsHorizontalScrollIndicator = false
        scrollView.showsVerticalScrollIndicator = false
        scrollView.alwaysBounceVertical = false
        scrollView.alwaysBounceHorizontal = false
        scrollView.contentInsetAdjustmentBehavior = .never

        let imageView = UIImageView(image: image)
        imageView.contentMode = .scaleAspectFit
        imageView.isUserInteractionEnabled = true
        imageView.translatesAutoresizingMaskIntoConstraints = false
        imageView.tag = 100

        scrollView.addSubview(imageView)

        NSLayoutConstraint.activate([
            imageView.leadingAnchor.constraint(equalTo: scrollView.contentLayoutGuide.leadingAnchor),
            imageView.trailingAnchor.constraint(equalTo: scrollView.contentLayoutGuide.trailingAnchor),
            imageView.topAnchor.constraint(equalTo: scrollView.contentLayoutGuide.topAnchor),
            imageView.bottomAnchor.constraint(equalTo: scrollView.contentLayoutGuide.bottomAnchor),
            imageView.widthAnchor.constraint(equalTo: scrollView.frameLayoutGuide.widthAnchor),
            imageView.heightAnchor.constraint(equalTo: scrollView.frameLayoutGuide.heightAnchor)
        ])

        let doubleTap = UITapGestureRecognizer(
            target: context.coordinator,
            action: #selector(Coordinator.handleDoubleTap(_:))
        )
        doubleTap.numberOfTapsRequired = 2
        scrollView.addGestureRecognizer(doubleTap)

        context.coordinator.scrollView = scrollView
        context.coordinator.imageView = imageView

        return scrollView
    }

    func updateUIView(_ scrollView: UIScrollView, context: Context) {
        if let imageView = scrollView.viewWithTag(100) as? UIImageView {
            imageView.image = image
        }

        scrollView.setZoomScale(1.0, animated: false)
        context.coordinator.centerImage()
    }

    func makeCoordinator() -> Coordinator {
        Coordinator()
    }

    class Coordinator: NSObject, UIScrollViewDelegate {
        weak var scrollView: UIScrollView?
        weak var imageView: UIImageView?

        func viewForZooming(in scrollView: UIScrollView) -> UIView? {
            imageView
        }

        func scrollViewDidZoom(_ scrollView: UIScrollView) {
            centerImage()
        }

        func centerImage() {
            guard let scrollView = scrollView,
                  let imageView = imageView else {
                return
            }

            let boundsSize = scrollView.bounds.size
            var frameToCenter = imageView.frame

            if frameToCenter.size.width < boundsSize.width {
                frameToCenter.origin.x = (boundsSize.width - frameToCenter.size.width) / 2
            } else {
                frameToCenter.origin.x = 0
            }

            if frameToCenter.size.height < boundsSize.height {
                frameToCenter.origin.y = (boundsSize.height - frameToCenter.size.height) / 2
            } else {
                frameToCenter.origin.y = 0
            }

            imageView.frame = frameToCenter
        }

        @objc func handleDoubleTap(_ gesture: UITapGestureRecognizer) {
            guard let scrollView = scrollView else {
                return
            }

            if scrollView.zoomScale > 1.0 {
                scrollView.setZoomScale(1.0, animated: true)
            } else {
                let point = gesture.location(in: imageView)
                let zoomScale: CGFloat = 2.7

                let width = scrollView.bounds.width / zoomScale
                let height = scrollView.bounds.height / zoomScale
                let x = point.x - (width / 2)
                let y = point.y - (height / 2)

                let rect = CGRect(
                    x: x,
                    y: y,
                    width: width,
                    height: height
                )

                scrollView.zoom(to: rect, animated: true)
            }
        }
    }
}

struct RoundListView: View {
    @EnvironmentObject var store: GolfRoundStore
    @State private var selectedYear = Calendar.current.component(.year, from: Date())

    var body: some View {
        NavigationStack {
            VStack(spacing: 0) {
                HStack {
                    Button {
                        withAnimation {
                            selectedYear -= 1
                        }
                    } label: {
                        Image(systemName: "chevron.left")
                            .font(.title2)
                    }

                    Spacer()

                    Text(store.language == .korean ? "\(selectedYear)년" : String(selectedYear))
                        .font(.title2)
                        .fontWeight(.bold)

                    Spacer()

                    Button {
                        withAnimation {
                            selectedYear += 1
                        }
                    } label: {
                        Image(systemName: "chevron.right")
                            .font(.title2)
                    }
                }
                .padding(.horizontal)
                .padding(.vertical, 8)

                TabView(selection: $selectedYear) {
                    ForEach(2000...2050, id: \.self) { year in
                        RoundListYearPageView(year: year)
                            .environmentObject(store)
                            .tag(year)
                    }
                }
                .tabViewStyle(.page(indexDisplayMode: .never))
            }
            .navigationTitle(text("rounds", store.language))
        }
    }
}

struct RoundListYearPageView: View {
    @EnvironmentObject var store: GolfRoundStore

    let year: Int

    @State private var selectedRound: GolfRound?

    var yearRounds: [GolfRound] {
        store.rounds
            .filter {
                $0.status == .round &&
                Calendar.current.component(.year, from: $0.date) == year
            }
            .sorted { $0.date < $1.date }
    }

    var body: some View {
        Group {
            if yearRounds.isEmpty {
                VStack {
                    Spacer()
                    Text(text("no_rounds", store.language))
                        .foregroundColor(.gray)
                    Spacer()
                }
            } else {
                List {
                    Section {
                        Button(
                            store.revealPrivateInfo ? text("hide_names", store.language) : text("show_names", store.language)
                        ) {
                            togglePrivacy()
                        }
                    }

                    ForEach(yearRounds) { round in
                        VStack(alignment: .leading, spacing: 6) {
                            Text(round.course)
                                .font(.headline)

                            Text(dateText(round.date))
                                .font(.subheadline)
                                .foregroundColor(.gray)

                            if !round.partners.isEmpty {
                                Text("\(text("partners", store.language)): \(maskedPartnerNames(round.partners, revealed: store.revealPrivateInfo))")
                                    .font(.subheadline)
                            }

                            if let myRank = myRankText(round) {
                                Text(myRank)
                                    .font(.caption)
                                    .foregroundColor(.blue)
                            }

                            if !round.memo.isEmpty {
                                Text("\(text("memo", store.language)): \(round.memo)")
                                    .font(.caption)
                                    .foregroundColor(.gray)
                            }

                            if !round.roundPhotoFileNames.isEmpty {
                                Text("\(text("round_photos_attached", store.language)) \(round.roundPhotoFileNames.count)")
                                    .font(.caption)
                                    .foregroundColor(.green)
                            }

                            if round.calendarEventID != nil {
                                Text(text("synced_calendar", store.language))
                                    .font(.caption)
                                    .foregroundColor(.blue)
                            }
                        }
                        .padding(.vertical, 4)
                        .contentShape(Rectangle())
                        .onTapGesture {
                            selectedRound = round
                        }
                    }
                    .onDelete(perform: delete)
                }
            }
        }
        .sheet(item: $selectedRound) { round in
            RoundEditorPagerView(initialDate: round.date)
                .environmentObject(store)
        }
    }

    func delete(at offsets: IndexSet) {
        let selected = offsets.map { yearRounds[$0] }
        selected.forEach { store.delete($0) }
    }

    func myRankText(_ round: GolfRound) -> String? {
        let ranked = round.scores
            .filter { $0.score != nil }
            .sorted { ($0.score ?? 999) < ($1.score ?? 999) }

        guard let index = ranked.firstIndex(where: { $0.isMe }) else {
            return nil
        }

        return "\(text("my_rank", store.language)): #\(index + 1) / \(ranked.count)"
    }

    func togglePrivacy() {
        if store.revealPrivateInfo {
            store.revealPrivateInfo = false
        } else {
            authenticateToReveal { success in
                if success {
                    store.revealPrivateInfo = true
                }
            }
        }
    }

    func dateText(_ date: Date) -> String {
        let formatter = DateFormatter()
        formatter.locale = store.language == .korean ? Locale(identifier: "ko_KR") : Locale(identifier: "en_US")
        formatter.dateFormat = store.language == .korean ? "yyyy년 M월 d일" : "MMM d, yyyy"
        return formatter.string(from: date)
    }
}

// ======================================================
// SECTION 10 / Stats View
// ======================================================

struct StatsView: View {
    @EnvironmentObject var store: GolfRoundStore
    @State private var selectedYear = Calendar.current.component(.year, from: Date())

    var body: some View {
        NavigationStack {
            VStack(spacing: 0) {
                HStack {
                    Button { withAnimation { selectedYear -= 1 } } label: {
                        Image(systemName: "chevron.left").font(.title2)
                    }

                    Spacer()

                    Text(store.language == .korean ? "\(selectedYear)년" : String(selectedYear))
                        .font(.title2)
                        .fontWeight(.bold)

                    Spacer()

                    Button { withAnimation { selectedYear += 1 } } label: {
                        Image(systemName: "chevron.right").font(.title2)
                    }
                }
                .padding(.horizontal)
                .padding(.vertical, 8)

                TabView(selection: $selectedYear) {
                    ForEach(2000...2050, id: \.self) { year in
                        StatsYearPageView(year: year)
                            .environmentObject(store)
                            .tag(year)
                    }
                }
                .tabViewStyle(.page(indexDisplayMode: .never))
            }
            .navigationTitle(text("stats", store.language))
            .toolbar {
                ToolbarItem(placement: .navigationBarTrailing) {
                    Button { togglePrivacy() } label: {
                        Image(systemName: store.revealPrivateInfo ? "lock.open.fill" : "lock.fill")
                    }
                }
            }
        }
    }

    func togglePrivacy() {
        if store.revealPrivateInfo {
            store.revealPrivateInfo = false
        } else {
            authenticateToReveal { success in
                if success { store.revealPrivateInfo = true }
            }
        }
    }
}

struct StatsYearPageView: View {
    @EnvironmentObject var store: GolfRoundStore
    let year: Int

    var yearRounds: [GolfRound] {
        store.rounds.filter {
            $0.status == .round && Calendar.current.component(.year, from: $0.date) == year
        }
    }

    var myScores: [Int] {
        yearRounds.flatMap { round in
            round.scores
                .filter { $0.isMe && $0.score != nil }
                .compactMap { $0.score }
        }
    }

    var body: some View {
        List {
            Section(text("round_summary", store.language)) {
                HStack {
                    Text(text("total_rounds", store.language))
                    Spacer()
                    Text("\(yearRounds.count)")
                }
                HStack {
                    Text(text("average_score", store.language))
                    Spacer()
                    Text(averageScoreText())
                }
                HStack {
                    Text(text("best_score", store.language))
                    Spacer()
                    Text(bestScoreText())
                }
            }

            Section(text("golf_courses", store.language)) {
                if rankCourses().isEmpty {
                    Text(text("no_data", store.language)).foregroundColor(.gray)
                } else {
                    ForEach(rankCourses(), id: \.0) { item in
                        HStack {
                            Text(item.0)
                            Spacer()
                            Text("\(item.1)")
                        }
                    }
                }
            }

            Section(text("partner_frequency", store.language)) {
                if rankPartners().isEmpty {
                    Text(text("no_data", store.language)).foregroundColor(.gray)
                } else {
                    ForEach(rankPartners(), id: \.0) { item in
                        HStack {
                            Text(store.revealPrivateInfo ? item.0 : maskName(item.0))
                            Spacer()
                            Text("\(item.1)")
                        }
                    }
                }
            }

            Section(text("winner_ranking", store.language)) {
                if winnerRanking().isEmpty {
                    Text(text("no_score_data", store.language)).foregroundColor(.gray)
                } else {
                    ForEach(winnerRanking(), id: \.0) { item in
                        HStack {
                            Text(store.revealPrivateInfo || item.0 == store.myName ? item.0 : maskName(item.0))
                            Spacer()
                            Text("\(item.1) \(text("wins", store.language))")
                        }
                    }
                }
            }
        }
    }

    func averageScoreText() -> String {
        guard !myScores.isEmpty else { return "-" }
        let avg = Double(myScores.reduce(0, +)) / Double(myScores.count)
        return String(format: "%.1f", avg)
    }

    func bestScoreText() -> String {
        guard let best = myScores.min() else { return "-" }
        return "\(best)"
    }

    func rankCourses() -> [(String, Int)] {
        let names = yearRounds.map { $0.course }.filter { !$0.isEmpty }
        return Dictionary(grouping: names, by: { $0 })
            .map { ($0.key, $0.value.count) }
            .sorted { $0.1 > $1.1 }
    }

    func rankPartners() -> [(String, Int)] {
        let names = yearRounds.flatMap { $0.partners }
        return Dictionary(grouping: names, by: { $0 })
            .map { ($0.key, $0.value.count) }
            .sorted { $0.1 > $1.1 }
    }

    func winnerRanking() -> [(String, Int)] {
        var winners: [String] = []
        for round in yearRounds {
            let ranked = round.scores
                .filter { $0.score != nil }
                .sorted { ($0.score ?? 999) < ($1.score ?? 999) }
            if let winner = ranked.first {
                winners.append(winner.name)
            }
        }
        return Dictionary(grouping: winners, by: { $0 })
            .map { ($0.key, $0.value.count) }
            .sorted { $0.1 > $1.1 }
    }
}

// ======================================================
// SECTION 11 / Settings, Backup & Helpers
// ======================================================

struct BackupView: View {
    @EnvironmentObject var store: GolfRoundStore
    @State private var showExporter = false
    @State private var showImporter = false

    var body: some View {
        NavigationStack {
            Form {
                Section(text("profile", store.language)) {
                    TextField(text("my_name", store.language), text: $store.myName)
                }

                Section(text("language", store.language)) {
                    Picker(text("language", store.language), selection: $store.language) {
                        Text(text("korean", store.language)).tag(AppLanguage.korean)
                        Text(text("english", store.language)).tag(AppLanguage.english)
                    }
                    .pickerStyle(.segmented)
                }

                Section(text("privacy", store.language)) {
                    Toggle(text("show_private", store.language), isOn: $store.revealPrivateInfo)
                }

                Section(text("backup", store.language)) {
                    Button(text("create_backup", store.language)) { showExporter = true }
                    Button(text("import_backup", store.language)) { showImporter = true }
                    Text(text("backup_note", store.language))
                        .font(.caption)
                        .foregroundColor(.gray)
                }

                Section(text("app", store.language)) {
                    Text("GolfSchedulePro V3")
                    Text(store.language == .korean ? "한국어 / 영어 선택 버전" : "Korean / English selectable version")
                        .foregroundColor(.secondary)
                }
            }
            .navigationTitle(text("settings", store.language))
            .fileExporter(
                isPresented: $showExporter,
                document: BackupDocument(data: store.backupData()),
                contentType: .json,
                defaultFilename: "GolfScheduleProBackup"
            ) { result in
                print(result)
            }
            .fileImporter(
                isPresented: $showImporter,
                allowedContentTypes: [.json]
            ) { result in
                switch result {
                case .success(let url):
                    if url.startAccessingSecurityScopedResource() {
                        defer { url.stopAccessingSecurityScopedResource() }
                        if let data = try? Data(contentsOf: url) {
                            store.importBackup(data)
                        }
                    }
                case .failure:
                    print("Import failed")
                }
            }
        }
    }
}

func maskedPartnerNames(_ names: [String], revealed: Bool) -> String {
    if revealed { return names.joined(separator: ", ") }
    return names.map { maskName($0) }.joined(separator: ", ")
}

func maskName(_ name: String) -> String {
    let chars = Array(name)
    if chars.count <= 1 { return name }
    if chars.count == 2 { return "\(chars[0])*" }
    var masked = chars
    masked[1] = "*"
    return String(masked)
}

func authenticateToReveal(completion: @escaping (Bool) -> Void) {
    let context = LAContext()
    var error: NSError?

    if context.canEvaluatePolicy(.deviceOwnerAuthentication, error: &error) {
        context.evaluatePolicy(
            .deviceOwnerAuthentication,
            localizedReason: "Unlock private partner names."
        ) { success, _ in
            DispatchQueue.main.async { completion(success) }
        }
    } else {
        completion(false)
    }
}

func openGoogleMaps(course: String, lang: AppLanguage) {
    let query = normalizedGoogleCourseQuery(course, lang: lang)
    guard !query.isEmpty else { return }
    openGoogleMapsSearch(query)
}

func openNearbyRestaurants(course: String, lang: AppLanguage) {
    let trimmedCourse = course.trimmingCharacters(in: .whitespacesAndNewlines)
    guard !trimmedCourse.isEmpty else { return }

    let query: String
    if lang == .korean {
        query = "\(trimmedCourse) 골프장 근처 맛집"
    } else {
        query = "restaurants near \(trimmedCourse) golf course Korea"
    }

    openGoogleMapsSearch(query)
}

func normalizedGoogleCourseQuery(_ course: String, lang: AppLanguage) -> String {
    let trimmed = course.trimmingCharacters(in: .whitespacesAndNewlines)
    guard !trimmed.isEmpty else { return "" }

    if lang == .korean {
        return "\(trimmed) 골프장"
    } else {
        return "\(trimmed) golf course Korea"
    }
}

func openGoogleMapsSearch(_ query: String) {
    let encoded = query.addingPercentEncoding(withAllowedCharacters: .urlQueryAllowed) ?? query
    let webURLString = "https://www.google.com/maps/search/?api=1&query=\(encoded)"

    if let webURL = URL(string: webURLString) {
        UIApplication.shared.open(webURL)
    }
}

