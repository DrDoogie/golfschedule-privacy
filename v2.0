struct RoundListYearPageView: View {
    @EnvironmentObject var store: GolfRoundStore

    let year: Int

    @State private var selectedRound: GolfRound?

    var yearRounds: [GolfRound] {
        store.rounds
            .filter {
                $0.status == .round &&
                Calendar.current.component(.year, from: $0.date) == year
            }
            .sorted { $0.date < $1.date }
    }

    var body: some View {
        Group {
            if yearRounds.isEmpty {
                VStack {
                    Spacer()
                    Text(text("no_rounds", store.language))
                        .foregroundColor(.gray)
                    Spacer()
                }
            } else {
                List {
                    Section {
                        Button(
                            store.revealPrivateInfo ? text("hide_names", store.language) : text("show_names", store.language)
                        ) {
                            togglePrivacy()
                        }
                    }

                    ForEach(yearRounds) { round in
                        VStack(alignment: .leading, spacing: 6) {
                            Text(round.course)
                                .font(.headline)

                            Text(dateText(round.date))
                                .font(.subheadline)
                                .foregroundColor(.gray)

                            if !round.partners.isEmpty {
                                Text("\(text("partners", store.language)): \(maskedPartnerNames(round.partners, revealed: store.revealPrivateInfo))")
                                    .font(.subheadline)
                            }

                            if let myRank = myRankText(round) {
                                Text(myRank)
                                    .font(.caption)
                                    .foregroundColor(.blue)
                            }

                            if !round.memo.isEmpty {
                                Text("\(text("memo", store.language)): \(round.memo)")
                                    .font(.caption)
                                    .foregroundColor(.gray)
                            }

                            if round.scoreImageFileName != nil {
                                Text(text("score_image_attached", store.language))
                                    .font(.caption)
                                    .foregroundColor(.green)
                            }

                            if round.calendarEventID != nil {
                                Text(text("synced_calendar", store.language))
                                    .font(.caption)
                                    .foregroundColor(.blue)
                            }
                        }
                        .padding(.vertical, 4)
                        .contentShape(Rectangle())
                        .onTapGesture {
                            selectedRound = round
                        }
                    }
                    .onDelete(perform: delete)
                }
            }
        }
        .sheet(item: $selectedRound) { round in
            RoundEditorPagerView(initialDate: round.date)
                .environmentObject(store)
        }
    }

    func delete(at offsets: IndexSet) {
        let selected = offsets.map { yearRounds[$0] }
        selected.forEach { store.delete($0) }
    }

    func myRankText(_ round: GolfRound) -> String? {
        let ranked = round.scores
            .filter { $0.score > 0 }
            .sorted { $0.score < $1.score }

        guard let index = ranked.firstIndex(where: { $0.isMe }) else {
            return nil
        }

        return "\(text("my_rank", store.language)): #\(index + 1) / \(ranked.count)"
    }

    func togglePrivacy() {
        if store.revealPrivateInfo {
            store.revealPrivateInfo = false
        } else {
            authenticateToReveal { success in
                if success {
                    store.revealPrivateInfo = true
                }
            }
        }
    }

    func dateText(_ date: Date) -> String {
        let formatter = DateFormatter()
        formatter.locale = store.language == .korean ? Locale(identifier: "ko_KR") : Locale(identifier: "en_US")
        formatter.dateFormat = store.language == .korean ? "yyyy년 M월 d일" : "MMM d, yyyy"
        return formatter.string(from: date)
    }
}

