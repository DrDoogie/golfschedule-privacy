struct StatsYearPageView: View {
    @EnvironmentObject var store: GolfRoundStore

    let year: Int

    var yearRounds: [GolfRound] {
        store.rounds.filter {
            $0.status == .round &&
            Calendar.current.component(.year, from: $0.date) == year
        }
    }

    var myScores: [Int] {
        yearRounds.flatMap { round in
            round.scores
                .filter { $0.isMe && $0.score > 0 }
                .map { $0.score }
        }
    }

    var body: some View {
        List {
            Section(text("round_summary", store.language)) {
                HStack {
                    Text(text("total_rounds", store.language))
                    Spacer()
                    Text("\(yearRounds.count)")
                }

                HStack {
                    Text(text("average_score", store.language))
                    Spacer()
                    Text(averageScoreText())
                }

                HStack {
                    Text(text("best_score", store.language))
                    Spacer()
                    Text(bestScoreText())
                }
            }

            Section(text("golf_courses", store.language)) {
                if rankCourses().isEmpty {
                    Text(text("no_data", store.language))
                        .foregroundColor(.gray)
                } else {
                    ForEach(rankCourses(), id: \.0) { item in
                        HStack {
                            Text(item.0)
                            Spacer()
                            Text("\(item.1)")
                        }
                    }
                }
            }

            Section(text("partner_frequency", store.language)) {
                if rankPartners().isEmpty {
                    Text(text("no_data", store.language))
                        .foregroundColor(.gray)
                } else {
                    ForEach(rankPartners(), id: \.0) { item in
                        HStack {
                            Text(store.revealPrivateInfo ? item.0 : maskName(item.0))
                            Spacer()
                            Text("\(item.1)")
                        }
                    }
                }
            }

            Section(text("winner_ranking", store.language)) {
                if winnerRanking().isEmpty {
                    Text(text("no_score_data", store.language))
                        .foregroundColor(.gray)
                } else {
                    ForEach(winnerRanking(), id: \.0) { item in
                        HStack {
                            Text(store.revealPrivateInfo || item.0 == store.myName ? item.0 : maskName(item.0))
                            Spacer()
                            Text("\(item.1) \(text("wins", store.language))")
                        }
                    }
                }
            }
        }
    }

    func averageScoreText() -> String {
        guard !myScores.isEmpty else { return "-" }
        let avg = Double(myScores.reduce(0, +)) / Double(myScores.count)
        return String(format: "%.1f", avg)
    }

    func bestScoreText() -> String {
        guard let best = myScores.min() else { return "-" }
        return "\(best)"
    }

    func rankCourses() -> [(String, Int)] {
        let names = yearRounds.map { $0.course }.filter { !$0.isEmpty }

        return Dictionary(grouping: names, by: { $0 })
            .map { ($0.key, $0.value.count) }
            .sorted { $0.1 > $1.1 }
    }

    func rankPartners() -> [(String, Int)] {
        let names = yearRounds.flatMap { $0.partners }

        return Dictionary(grouping: names, by: { $0 })
            .map { ($0.key, $0.value.count) }
            .sorted { $0.1 > $1.1 }
    }

    func winnerRanking() -> [(String, Int)] {
        var winners: [String] = []

        for round in yearRounds {
            let ranked = round.scores
                .filter { $0.score > 0 }
                .sorted { $0.score < $1.score }

            if let winner = ranked.first {
                winners.append(winner.name)
            }
        }

        return Dictionary(grouping: winners, by: { $0 })
            .map { ($0.key, $0.value.count) }
            .sorted { $0.1 > $1.1 }
    }
}

// ======================================================
// SECTION 11 / Settings, Backup & Helpers
// ======================================================

struct BackupView: View {
    @EnvironmentObject var store: GolfRoundStore

    @State private var showExporter = false
    @State private var showImporter = false

    var body: some View {
        NavigationStack {
            Form {
                Section(text("profile", store.language)) {
                    TextField(text("my_name", store.language), text: $store.myName)
                }

                Section(text("language", store.language)) {
                    Picker(text("language", store.language), selection: $store.language) {
                        Text(text("korean", store.language)).tag(AppLanguage.korean)
                        Text(text("english", store.language)).tag(AppLanguage.english)
                    }
                    .pickerStyle(.segmented)
                }

                Section(text("privacy", store.language)) {
                    Toggle(text("show_private", store.language), isOn: $store.revealPrivateInfo)
                }

                Section(text("backup", store.language)) {
                    Button(text("create_backup", store.language)) {
                        showExporter = true
                    }

                    Button(text("import_backup", store.language)) {
                        showImporter = true
                    }

                    Text(text("backup_note", store.language))
                        .font(.caption)
                        .foregroundColor(.gray)
                }

                Section(text("app", store.language)) {
                    Text("GolfSchedulePro V2")
                    Text(
                        store.language == .korean
                        ? "한국어 / 영어 선택 버전"
                        : "Korean / English selectable version"
                    )
                    .foregroundColor(.secondary)
                }
            }
            .navigationTitle(text("settings", store.language))
            .fileExporter(
                isPresented: $showExporter,
                document: BackupDocument(data: store.backupData()),
                contentType: .json,
                defaultFilename: "GolfScheduleProBackup"
            ) { result in
                print(result)
            }
            .fileImporter(
                isPresented: $showImporter,
                allowedContentTypes: [.json]
            ) { result in
                switch result {

                case .success(let url):

                    if url.startAccessingSecurityScopedResource() {

                        defer {
                            url.stopAccessingSecurityScopedResource()
                        }

                        if let data = try? Data(contentsOf: url) {
                            store.importBackup(data)
                        }
                    }

                case .failure:
                    print("Import failed")
                }
            }
        }
    }
}

func maskedPartnerNames(_ names: [String], revealed: Bool) -> String {
    if revealed {
        return names.joined(separator: ", ")
    }

    return names.map { maskName($0) }
        .joined(separator: ", ")
}

func maskName(_ name: String) -> String {
    let chars = Array(name)

    if chars.count <= 1 {
        return name
    } else if chars.count == 2 {
        return "\(chars[0])*"
    } else {
        var masked = chars
        masked[1] = "*"
        return String(masked)
    }
}

func authenticateToReveal(
    completion: @escaping (Bool) -> Void
) {
    let context = LAContext()
    var error: NSError?

    if context.canEvaluatePolicy(
        .deviceOwnerAuthentication,
        error: &error
    ) {
        context.evaluatePolicy(
            .deviceOwnerAuthentication,
            localizedReason: "Unlock private partner names."
        ) { success, _ in
            DispatchQueue.main.async {
                completion(success)
            }
        }
    } else {
        completion(false)
    }
}

// MARK: - Google Maps

func openGoogleMaps(
    course: String,
    lang: AppLanguage
) {
    let query = normalizedGoogleCourseQuery(
        course,
        lang: lang
    )

    guard !query.isEmpty else {
        return
    }

    openGoogleMapsSearch(query)
}

func openNearbyRestaurants(
    course: String,
    lang: AppLanguage
) {
    let trimmedCourse = course.trimmingCharacters(
        in: .whitespacesAndNewlines
    )

    guard !trimmedCourse.isEmpty else {
        return
    }

    let query: String

    if lang == .korean {
        query = "\(trimmedCourse) 골프장 근처 맛집"
    } else {
        query = "restaurants near \(trimmedCourse) golf course Korea"
    }

    openGoogleMapsSearch(query)
}

func normalizedGoogleCourseQuery(
    _ course: String,
    lang: AppLanguage
) -> String {
    let trimmed = course.trimmingCharacters(
        in: .whitespacesAndNewlines
    )

    guard !trimmed.isEmpty else {
        return ""
    }

    if lang == .korean {
        return "\(trimmed) 골프장"
    } else {
        return "\(trimmed) golf course Korea"
    }
}

func openGoogleMapsSearch(
    _ query: String
) {
    let encoded =
        query.addingPercentEncoding(
            withAllowedCharacters: .urlQueryAllowed
        ) ?? query

    let appURLString =
        "comgooglemaps://?q=\(encoded)"

    let webURLString =
        "https://www.google.com/maps/search/?api=1&query=\(encoded)"

    if let appURL = URL(string: appURLString),
       UIApplication.shared.canOpenURL(appURL) {
        UIApplication.shared.open(appURL)
        return
    }

    if let webURL = URL(string: webURLString) {
        UIApplication.shared.open(webURL)
    }
}

