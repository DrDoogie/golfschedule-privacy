// ======================================================
// SECTION 03 / Apple Calendar Manager
// ======================================================

class CalendarManager {
    static let eventStore = EKEventStore()

    static func requestAccess() {
        if #available(iOS 17.0, *) {
            eventStore.requestFullAccessToEvents { granted, error in
                print("Apple Calendar full access:", granted, error?.localizedDescription ?? "")
            }
        } else {
            eventStore.requestAccess(to: .event) { granted, error in
                print("Apple Calendar access:", granted, error?.localizedDescription ?? "")
            }
        }
    }

    static func sync(_ round: GolfRound, lang: AppLanguage) -> GolfRound {
        var updated = round

        if round.status != .round {
            if let id = round.calendarEventID {
                delete(id)
            }
            updated.calendarEventID = nil
            return updated
        }

        if let id = round.calendarEventID,
           let event = eventStore.event(withIdentifier: id) {
            apply(round, to: event, lang: lang)
            do {
                try eventStore.save(event, span: .thisEvent)
                updated.calendarEventID = event.eventIdentifier
            } catch {
                print("Calendar update failed:", error)
            }
            return updated
        }

        let event = EKEvent(eventStore: eventStore)
        apply(round, to: event, lang: lang)
        event.calendar = eventStore.defaultCalendarForNewEvents

        do {
            try eventStore.save(event, span: .thisEvent)
            updated.calendarEventID = event.eventIdentifier
        } catch {
            print("Calendar create failed:", error)
        }

        return updated
    }

    static func delete(_ identifier: String) {
        guard let event = eventStore.event(withIdentifier: identifier) else { return }
        do {
            try eventStore.remove(event, span: .thisEvent)
        } catch {
            print("Calendar delete failed:", error)
        }
    }

    private static func apply(_ round: GolfRound, to event: EKEvent, lang: AppLanguage) {
        let title = round.course.isEmpty ? text("golf_round", lang) : round.course
        event.title = "⛳️ \(title)"

        if let teeTime = round.teeTime {
            let startDate = combinedDate(day: round.date, time: teeTime)
            let endDate = Calendar.current.date(byAdding: .hour, value: 5, to: startDate) ?? startDate
            event.startDate = startDate
            event.endDate = endDate
            event.isAllDay = false
        } else {
            let start = Calendar.current.startOfDay(for: round.date)
            let end = Calendar.current.date(byAdding: .day, value: 1, to: start) ?? start
            event.startDate = start
            event.endDate = end
            event.isAllDay = true
        }

        var notes = lang == .korean ? "GolfSchedulePro에서 생성한 일정입니다." : "Created by GolfSchedulePro."
        if !round.memo.isEmpty {
            notes += "\n\n\(text("memo", lang)): \(round.memo)"
        }
        event.notes = notes
    }

    private static func combinedDate(day: Date, time: Date) -> Date {
        let calendar = Calendar.current
        let dayComponents = calendar.dateComponents([.year, .month, .day], from: day)
        let timeComponents = calendar.dateComponents([.hour, .minute], from: time)

        var components = DateComponents()
        components.year = dayComponents.year
        components.month = dayComponents.month
        components.day = dayComponents.day
        components.hour = timeComponents.hour
        components.minute = timeComponents.minute

        return calendar.date(from: components) ?? day
    }
}

// ======================================================
// SECTION 04 / Store & Backup Document
// ======================================================

class GolfRoundStore: ObservableObject {
    @Published var revealPrivateInfo = false
    @Published var rounds: [GolfRound] = GolfRoundStore.loadRounds()

    @Published var myName: String = UserDefaults.standard.string(forKey: "my_name") ?? "Me" {
        didSet { UserDefaults.standard.set(myName, forKey: "my_name") }
    }

    @Published var language: AppLanguage = {
        let raw = UserDefaults.standard.string(forKey: "app_language") ?? AppLanguage.korean.rawValue
        return AppLanguage(rawValue: raw) ?? .korean
    }() {
        didSet { UserDefaults.standard.set(language.rawValue, forKey: "app_language") }
    }

    private static let key = "golf_rounds_v2"

    static func loadRounds() -> [GolfRound] {
        guard let data = UserDefaults.standard.data(forKey: key) else { return [] }
        do {
            return try JSONDecoder().decode([GolfRound].self, from: data)
        } catch {
            print("Load failed:", error)
            return []
        }
    }

    func save() {
        do {
            let data = try JSONEncoder().encode(rounds)
            UserDefaults.standard.set(data, forKey: GolfRoundStore.key)
        } catch {
            print("Save failed:", error)
        }
    }

    func round(on date: Date) -> GolfRound? {
        rounds.first { Calendar.current.isDate($0.date, inSameDayAs: date) }
    }

    func upsert(_ round: GolfRound) {
        if let index = rounds.firstIndex(where: { $0.id == round.id }) {
            rounds[index] = round
        } else {
            rounds.append(round)
        }
        save()
    }

    func delete(_ round: GolfRound) {
        if let id = round.calendarEventID {
            CalendarManager.delete(id)
        }
        for fileName in round.roundPhotoFileNames {
            deleteRoundPhoto(fileName: fileName)
        }
        rounds.removeAll { $0.id == round.id }
        save()
    }

    func backupData() -> Data {
        do {
            return try JSONEncoder().encode(rounds)
        } catch {
            return Data()
        }
    }

    func importBackup(_ data: Data) {
        do {
            rounds = try JSONDecoder().decode([GolfRound].self, from: data)
            save()
        } catch {
            print("Import failed:", error)
        }
    }

    func saveRoundPhoto(_ data: Data) -> String? {
        let fileName = UUID().uuidString + ".jpg"
        let url = documentsURL().appendingPathComponent(fileName)
        do {
            try data.write(to: url)
            return fileName
        } catch {
            print("Photo save failed:", error)
            return nil
        }
    }

    func imageURL(fileName: String) -> URL {
        documentsURL().appendingPathComponent(fileName)
    }

    func deleteRoundPhoto(fileName: String) {
        let url = imageURL(fileName: fileName)
        do {
            try FileManager.default.removeItem(at: url)
        } catch {
            print("Photo delete failed:", error)
        }
    }

    private func documentsURL() -> URL {
        FileManager.default.urls(for: .documentDirectory, in: .userDomainMask)[0]
    }
}

struct BackupDocument: FileDocument {
    static var readableContentTypes: [UTType] { [.json] }
    var data: Data

    init(data: Data) { self.data = data }

    init(configuration: ReadConfiguration) throws {
        self.data = configuration.file.regularFileContents ?? Data()
    }

    func fileWrapper(configuration: WriteConfiguration) throws -> FileWrapper {
        FileWrapper(regularFileWithContents: data)
    }
}

// ======================================================
// SECTION 05 / Main Content & Calendar View
// ======================================================

struct ContentView: View {
    @StateObject private var store = GolfRoundStore()

    var body: some View {
        TabView {
            CalendarView()
                .environmentObject(store)
                .tabItem { Label(text("calendar", store.language), systemImage: "calendar") }

            RoundListView()
                .environmentObject(store)
                .tabItem { Label(text("rounds", store.language), systemImage: "list.bullet") }

            StatsView()
                .environmentObject(store)
                .tabItem { Label(text("stats", store.language), systemImage: "chart.bar") }

            BackupView()
                .environmentObject(store)
                .tabItem { Label(text("settings", store.language), systemImage: "gearshape") }
        }
        .onAppear { CalendarManager.requestAccess() }
    }
}

struct CalendarView: View {
    @EnvironmentObject var store: GolfRoundStore
    @State private var monthIndex = 0
    @State private var selectedDate: DateSelection?

    var weekdays: [String] {
        store.language == .korean ? ["일", "월", "화", "수", "목", "금", "토"] : ["Su", "Mo", "Tu", "We", "Th", "Fr", "Sa"]
    }

    var currentMonth: Date {
        Calendar.current.date(byAdding: .month, value: monthIndex, to: Date()) ?? Date()
    }

    var body: some View {
        NavigationStack {
            VStack(spacing: 8) {
                HStack {
                    Button { withAnimation { monthIndex -= 1 } } label: {
                        Image(systemName: "chevron.left").font(.title2)
                    }

                    Spacer()

                    Text(monthTitle(currentMonth))
                        .font(.title2)
                        .fontWeight(.bold)

                    Spacer()

                    Button { withAnimation { monthIndex += 1 } } label: {
                        Image(systemName: "chevron.right").font(.title2)
                    }
                }
                .padding(.horizontal)

                HStack {
                    ForEach(weekdays, id: \.self) { day in
                        Text(day)
                            .font(.headline)
                            .foregroundColor(day == weekdays.first ? .red : day == weekdays.last ? .blue : .primary)
                            .frame(maxWidth: .infinity)
                    }
                }
                .padding(.horizontal, 4)

                TabView(selection: $monthIndex) {
                    ForEach(-120...120, id: \.self) { index in
                        MonthPageView(
                            monthDate: Calendar.current.date(byAdding: .month, value: index, to: Date()) ?? Date(),
                            selectedDate: $selectedDate
                        )
                        .environmentObject(store)
                        .tag(index)
                    }
                }
                .tabViewStyle(.page(indexDisplayMode: .never))

                HStack(spacing: 20) {
                    Label(text("golf_round", store.language), systemImage: "circle.fill")
                        .foregroundColor(.green)
                    Label(text("unavailable", store.language), systemImage: "xmark")
                        .foregroundColor(.red)
                }
                .font(.caption)

                Spacer()
            }
            .navigationTitle(text("golf_schedule", store.language))
            .toolbar {
                ToolbarItem(placement: .navigationBarTrailing) {
                    if monthIndex != 0 {
                        Button { withAnimation { monthIndex = 0 } } label: {
                            Label(text("today", store.language), systemImage: "calendar.circle")
                        }
                    }
                }
            }
            .sheet(item: $selectedDate) { selection in
                RoundEditorPagerView(initialDate: selection.date)
                    .environmentObject(store)
            }
        }
    }

    func monthTitle(_ date: Date) -> String {
        let formatter = DateFormatter()
        formatter.locale = store.language == .korean ? Locale(identifier: "ko_KR") : Locale(identifier: "en_US")
        formatter.dateFormat = store.language == .korean ? "yyyy년 M월" : "MMM yyyy"
        return formatter.string(from: date)
    }
}

// ======================================================
// SECTION 06 / Month Page & Day Cell
// ======================================================

struct MonthPageView: View {
    @EnvironmentObject var store: GolfRoundStore
    let monthDate: Date
    @Binding var selectedDate: DateSelection?

    private let columns = Array(repeating: GridItem(.flexible(), spacing: 2), count: 7)

    var body: some View {
        VStack {
            LazyVGrid(columns: columns, spacing: 4) {
                ForEach(calendarDays(), id: \.self) { date in
                    Button {
                        selectedDate = DateSelection(date: date)
                    } label: {
                        DayCell(date: date, currentMonth: monthDate, round: store.round(on: date))
                    }
                    .buttonStyle(.plain)
                    .contentShape(Rectangle())
                }
            }
            .padding(.horizontal, 4)
            .padding(.top, 4)

            Spacer()
        }
    }

    func calendarDays() -> [Date] {
        let calendar = Calendar.current
        let startOfMonth = calendar.date(from: calendar.dateComponents([.year, .month], from: monthDate))!
        let range = calendar.range(of: .day, in: .month, for: startOfMonth)!
        let firstWeekday = calendar.component(.weekday, from: startOfMonth)

        var days: [Date] = []

        if firstWeekday > 1 {
            for i in 0..<(firstWeekday - 1) {
                if let date = calendar.date(byAdding: .day, value: i - (firstWeekday - 1), to: startOfMonth) {
                    days.append(date)
                }
            }
        }

        for day in range {
            if let date = calendar.date(byAdding: .day, value: day - 1, to: startOfMonth) {
                days.append(date)
            }
        }

        while days.count < 42 {
            if let last = days.last,
               let next = calendar.date(byAdding: .day, value: 1, to: last) {
                days.append(next)
            }
        }

        return days
    }
}

struct DayCell: View {
    let date: Date
    let currentMonth: Date
    let round: GolfRound?

    var body: some View {
        VStack(spacing: 4) {
            Text("\(Calendar.current.component(.day, from: date))")
                .font(.system(size: 20, weight: .semibold))
                .foregroundColor(textColor)
                .strikethrough(round?.status == .unavailable, color: .red)
                .frame(width: 38, height: 38)
                .background(todayBackground)
                .clipShape(Circle())

            if round?.status == .round {
                Circle().fill(Color.green).frame(width: 7, height: 7)
            } else if round?.status == .unavailable {
                Circle().fill(Color.red).frame(width: 7, height: 7)
            } else {
                Circle().fill(Color.clear).frame(width: 7, height: 7)
            }
        }
        .frame(height: 68)
        .frame(maxWidth: .infinity)
        .background(cellBackground)
        .cornerRadius(10)
    }

    var textColor: Color {
        if !Calendar.current.isDate(date, equalTo: currentMonth, toGranularity: .month) {
            return .gray.opacity(0.4)
        }
        let weekday = Calendar.current.component(.weekday, from: date)
        if weekday == 1 { return .red }
        if weekday == 7 { return .blue }
        return .primary
    }

    var todayBackground: Color {
        Calendar.current.isDateInToday(date) ? Color.green.opacity(0.25) : Color.clear
    }

    var cellBackground: Color {
        if round?.status == .round { return Color.green.opacity(0.13) }
        if round?.status == .unavailable { return Color.red.opacity(0.10) }
        return Color.gray.opacity(0.06)
    }
}

