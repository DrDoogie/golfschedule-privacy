// ======================================================
// SECTION 01 / Imports & Basic Types
// ======================================================

import SwiftUI
import Combine
import PhotosUI
import UniformTypeIdentifiers
import UIKit
import LocalAuthentication
import EventKit
import MapKit

enum AppLanguage: String, Codable, CaseIterable {
    case korean
    case english
}

enum RoundStatus: String, Codable {
    case round
    case unavailable
}

struct DateSelection: Identifiable {
    let id = UUID()
    let date: Date
}

struct PlayerScore: Identifiable, Codable, Equatable {
    var id: UUID = UUID()
    var name: String
    var score: Int
    var isMe: Bool
}

struct GolfRound: Identifiable, Codable {
    var id: UUID
    var date: Date
    var course: String
    var partners: [String]
    var memo: String
    var status: RoundStatus
    var scores: [PlayerScore]
    var scoreImageFileName: String?
    var calendarEventID: String?
    var teeTime: Date?

    init(
        id: UUID = UUID(),
        date: Date,
        course: String = "",
        partners: [String] = [],
        memo: String = "",
        status: RoundStatus = .round,
        scores: [PlayerScore] = [],
        scoreImageFileName: String? = nil,
        calendarEventID: String? = nil,
        teeTime: Date? = nil
    ) {
        self.id = id
        self.date = date
        self.course = course
        self.partners = partners
        self.memo = memo
        self.status = status
        self.scores = scores
        self.scoreImageFileName = scoreImageFileName
        self.calendarEventID = calendarEventID
        self.teeTime = teeTime
    }
}

