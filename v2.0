// ======================================================
// SECTION 03 / Apple Calendar Manager
// ======================================================

class CalendarManager {
    static let eventStore = EKEventStore()

    static func requestAccess() {
        if #available(iOS 17.0, *) {
            eventStore.requestFullAccessToEvents { granted, error in
                print("Apple Calendar full access:", granted, error?.localizedDescription ?? "")
            }
        } else {
            eventStore.requestAccess(to: .event) { granted, error in
                print("Apple Calendar access:", granted, error?.localizedDescription ?? "")
            }
        }
    }

    static func sync(_ round: GolfRound, lang: AppLanguage) -> GolfRound {
        var updated = round

        if round.status != .round {
            if let id = round.calendarEventID {
                delete(id)
            }
            updated.calendarEventID = nil
            return updated
        }

        if let id = round.calendarEventID,
           let event = eventStore.event(withIdentifier: id) {
            apply(round, to: event, lang: lang)

            do {
                try eventStore.save(event, span: .thisEvent)
                updated.calendarEventID = event.eventIdentifier
            } catch {
                print("Calendar update failed:", error)
            }

            return updated
        }

        let event = EKEvent(eventStore: eventStore)
        apply(round, to: event, lang: lang)
        event.calendar = eventStore.defaultCalendarForNewEvents

        do {
            try eventStore.save(event, span: .thisEvent)
            updated.calendarEventID = event.eventIdentifier
        } catch {
            print("Calendar create failed:", error)
        }

        return updated
    }

    static func delete(_ identifier: String) {
        guard let event = eventStore.event(withIdentifier: identifier) else {
            return
        }

        do {
            try eventStore.remove(event, span: .thisEvent)
        } catch {
            print("Calendar delete failed:", error)
        }
    }

    private static func apply(_ round: GolfRound, to event: EKEvent, lang: AppLanguage) {
        let title = round.course.isEmpty ? text("golf_round", lang) : round.course
        event.title = "⛳️ \(title)"

        if let teeTime = round.teeTime {
            let startDate = combinedDate(day: round.date, time: teeTime)
            let endDate = Calendar.current.date(byAdding: .hour, value: 5, to: startDate) ?? startDate

            event.startDate = startDate
            event.endDate = endDate
            event.isAllDay = false
        } else {
            let start = Calendar.current.startOfDay(for: round.date)
            let end = Calendar.current.date(byAdding: .day, value: 1, to: start) ?? start

            event.startDate = start
            event.endDate = end
            event.isAllDay = true
        }

        var notes = lang == .korean ? "GolfSchedulePro에서 생성한 일정입니다." : "Created by GolfSchedulePro."

        if !round.memo.isEmpty {
            notes += "\n\n\(text("memo", lang)): \(round.memo)"
        }

        event.notes = notes
    }

    private static func combinedDate(day: Date, time: Date) -> Date {
        let calendar = Calendar.current
        let dayComponents = calendar.dateComponents([.year, .month, .day], from: day)
        let timeComponents = calendar.dateComponents([.hour, .minute], from: time)

        var components = DateComponents()
        components.year = dayComponents.year
        components.month = dayComponents.month
        components.day = dayComponents.day
        components.hour = timeComponents.hour
        components.minute = timeComponents.minute

        return calendar.date(from: components) ?? day
    }
}

// ======================================================
// SECTION 04 / Store & Backup Document
// ======================================================

class GolfRoundStore: ObservableObject {
    @Published var revealPrivateInfo = false
    @Published var rounds: [GolfRound] = GolfRoundStore.loadRounds()

    @Published var myName: String = UserDefaults.standard.string(forKey: "my_name") ?? "Me" {
        didSet {
            UserDefaults.standard.set(myName, forKey: "my_name")
        }
    }

    @Published var language: AppLanguage = {
        let raw = UserDefaults.standard.string(forKey: "app_language") ?? AppLanguage.korean.rawValue
        return AppLanguage(rawValue: raw) ?? .korean
    }() {
        didSet {
            UserDefaults.standard.set(language.rawValue, forKey: "app_language")
        }
    }

    private static let key = "golf_rounds_v2"

    static func loadRounds() -> [GolfRound] {
        guard let data = UserDefaults.standard.data(forKey: key) else {
            return []
        }

        do {
            return try JSONDecoder().decode([GolfRound].self, from: data)
        } catch {
            print("Load failed:", error)
            return []
        }
    }

    func save() {
        do {
            let data = try JSONEncoder().encode(rounds)
            UserDefaults.standard.set(data, forKey: GolfRoundStore.key)
        } catch {
            print("Save failed:", error)
        }
    }

    func round(on date: Date) -> GolfRound? {
        rounds.first {
            Calendar.current.isDate($0.date, inSameDayAs: date)
        }
    }

    func upsert(_ round: GolfRound) {
        if let index = rounds.firstIndex(where: { $0.id == round.id }) {
            rounds[index] = round
        } else {
            rounds.append(round)
        }
        save()
    }

    func delete(_ round: GolfRound) {
        if let id = round.calendarEventID {
            CalendarManager.delete(id)
        }

        rounds.removeAll { $0.id == round.id }
        save()
    }

    func backupData() -> Data {
        do {
            return try JSONEncoder().encode(rounds)
        } catch {
            return Data()
        }
    }

    func importBackup(_ data: Data) {
        do {
            rounds = try JSONDecoder().decode([GolfRound].self, from: data)
            save()
        } catch {
            print("Import failed:", error)
        }
    }

    func saveScoreImage(_ data: Data) -> String? {
        let fileName = UUID().uuidString + ".jpg"
        let url = documentsURL().appendingPathComponent(fileName)

        do {
            try data.write(to: url)
            return fileName
        } catch {
            print("Image save failed:", error)
            return nil
        }
    }

    func imageURL(fileName: String) -> URL {
        documentsURL().appendingPathComponent(fileName)
    }

    private func documentsURL() -> URL {
        FileManager.default.urls(for: .documentDirectory, in: .userDomainMask)[0]
    }
}

struct BackupDocument: FileDocument {
    static var readableContentTypes: [UTType] {
        [.json]
    }

    var data: Data

    init(data: Data) {
        self.data = data
    }

    init(configuration: ReadConfiguration) throws {
        self.data = configuration.file.regularFileContents ?? Data()
    }

    func fileWrapper(configuration: WriteConfiguration) throws -> FileWrapper {
        FileWrapper(regularFileWithContents: data)
    }
}

