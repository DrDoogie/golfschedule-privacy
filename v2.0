// ======================================================
// SECTION 01 / Imports & Basic Types
// ======================================================

import SwiftUI
import Combine
import PhotosUI
import UniformTypeIdentifiers
import UIKit
import LocalAuthentication
import EventKit
import MapKit

enum AppLanguage: String, Codable, CaseIterable {
    case korean
    case english
}

enum RoundStatus: String, Codable {
    case round
    case unavailable
}

struct DateSelection: Identifiable {
    let id = UUID()
    let date: Date
}

struct PlayerScore: Identifiable, Codable, Equatable {
    var id: UUID
    var name: String
    var score: Int?
    var isMe: Bool

    init(
        id: UUID = UUID(),
        name: String,
        score: Int? = nil,
        isMe: Bool
    ) {
        self.id = id
        self.name = name
        self.score = score
        self.isMe = isMe
    }

    enum CodingKeys: String, CodingKey {
        case id, name, score, isMe
    }

    init(from decoder: Decoder) throws {
        let container = try decoder.container(keyedBy: CodingKeys.self)

        id = try container.decodeIfPresent(UUID.self, forKey: .id) ?? UUID()
        name = try container.decodeIfPresent(String.self, forKey: .name) ?? ""

        let decodedScore = try container.decodeIfPresent(Int.self, forKey: .score)
        score = (decodedScore != nil && decodedScore! > 0) ? decodedScore : nil

        isMe = try container.decodeIfPresent(Bool.self, forKey: .isMe) ?? false
    }
}

struct GolfRound: Identifiable, Codable {
    var id: UUID
    var date: Date
    var course: String
    var partners: [String]
    var memo: String
    var status: RoundStatus
    var scores: [PlayerScore]
    var roundPhotoFileNames: [String]
    var calendarEventID: String?
    var teeTime: Date?

    init(
        id: UUID = UUID(),
        date: Date,
        course: String = "",
        partners: [String] = [],
        memo: String = "",
        status: RoundStatus = .round,
        scores: [PlayerScore] = [],
        roundPhotoFileNames: [String] = [],
        calendarEventID: String? = nil,
        teeTime: Date? = nil
    ) {
        self.id = id
        self.date = date
        self.course = course
        self.partners = partners
        self.memo = memo
        self.status = status
        self.scores = scores
        self.roundPhotoFileNames = roundPhotoFileNames
        self.calendarEventID = calendarEventID
        self.teeTime = teeTime
    }

    enum CodingKeys: String, CodingKey {
        case id
        case date
        case course
        case partners
        case memo
        case status
        case scores
        case roundPhotoFileNames
        case scoreImageFileName
        case calendarEventID
        case teeTime
    }

    init(from decoder: Decoder) throws {
        let container = try decoder.container(keyedBy: CodingKeys.self)

        id = try container.decodeIfPresent(UUID.self, forKey: .id) ?? UUID()
        date = try container.decode(Date.self, forKey: .date)
        course = try container.decodeIfPresent(String.self, forKey: .course) ?? ""
        memo = try container.decodeIfPresent(String.self, forKey: .memo) ?? ""

        partners = []
        if let partnerArray = try? container.decode([String].self, forKey: .partners) {
            partners = partnerArray
        } else if let partnerText = try? container.decode(String.self, forKey: .partners) {
            partners = partnerText
                .split(separator: ",")
                .map { String($0).trimmingCharacters(in: .whitespacesAndNewlines) }
                .filter { !$0.isEmpty }
        }

        let rawStatus = try container.decodeIfPresent(String.self, forKey: .status) ?? "round"
        status = (rawStatus == "golf" || rawStatus == "round") ? .round : .unavailable

        scores = try container.decodeIfPresent([PlayerScore].self, forKey: .scores) ?? []

        roundPhotoFileNames = []
        if let photos = try? container.decode([String].self, forKey: .roundPhotoFileNames) {
            roundPhotoFileNames = photos
        } else if let oldImage = try? container.decode(String.self, forKey: .scoreImageFileName) {
            if !oldImage.isEmpty {
                roundPhotoFileNames = [oldImage]
            }
        }

        calendarEventID = try container.decodeIfPresent(String.self, forKey: .calendarEventID)
        teeTime = try container.decodeIfPresent(Date.self, forKey: .teeTime)
    }

    func encode(to encoder: Encoder) throws {
        var container = encoder.container(keyedBy: CodingKeys.self)

        try container.encode(id, forKey: .id)
        try container.encode(date, forKey: .date)
        try container.encode(course, forKey: .course)
        try container.encode(partners, forKey: .partners)
        try container.encode(memo, forKey: .memo)
        try container.encode(status, forKey: .status)
        try container.encode(scores, forKey: .scores)
        try container.encode(roundPhotoFileNames, forKey: .roundPhotoFileNames)
        try container.encodeIfPresent(calendarEventID, forKey: .calendarEventID)
        try container.encodeIfPresent(teeTime, forKey: .teeTime)
    }
}


